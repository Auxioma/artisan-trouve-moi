<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mot de passe oublié — TrouveMoi Prestataires</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700;12..96,800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="css/auth.css">
</head>
<body class="auth-body">

  <div class="auth-layout">
    <aside class="auth-brand d-none d-lg-flex" aria-hidden="true">
      <a href="trouvemoi-accueil.html" class="auth-brand__logo">
        <svg width="42" height="42" viewBox="0 0 48 48" fill="none" aria-hidden="true"><path d="M24 4C14.6 4 7 11.6 7 21c0 11.8 17 23 17 23s17-11.2 17-23C41 11.6 33.4 4 24 4z" fill="#FF8A1E" stroke="#0A1633" stroke-width="3.4" stroke-linejoin="round"/><circle cx="24" cy="20.5" r="6.6" fill="#fff"/></svg>
        <span><span class="auth-brand__name">TrouveMoi</span><br><span class="auth-brand__sub">Prestataires</span></span>
      </a>

      <div class="auth-brand__body">
        <span class="auth-eyebrow"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2 4 14h6l-1 8 9-12h-6z"/></svg>Récupération sécurisée</span>
        <h1 class="auth-brand__title">Un oubli ? Ça arrive <em>aux meilleurs artisans</em>.</h1>
        <p class="auth-brand__copy">Indiquez votre e-mail : nous vous envoyons immédiatement un lien sécurisé, valable une heure.</p>

        <!-- Aperçu produit — pur CSS, aucun visuel externe -->
        <div class="auth-preview">
          <div class="preview-card preview-card--demande">
            <span class="preview-card__thumb"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.8"/><path d="m21 15-4.5-4.5L6 21"/></svg></span>
            <span class="preview-card__lines">
              <i class="ph-line ph-line--fonce ph-line--70"></i>
              <i class="ph-line"></i>
              <i class="ph-line ph-line--45"></i>
            </span>
            <span class="preview-card__badge">NOUVELLE DEMANDE</span>
          </div>
          <div class="preview-card preview-card--note">
            <span class="preview-card__note">4,8<small>/5</small></span>
            <span class="preview-card__stars"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg></span>
            <span class="preview-card__sub">256 avis vérifiés</span>
          </div>
          <div class="preview-card preview-card--devis">
            <span class="preview-card__icone"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg></span>
            <span><b>Devis accepté</b><span>2 850 € · Rénovation salle de bain</span></span>
          </div>
        </div>
      </div>

      <div class="auth-brand__stats">
        <div class="auth-stat"><b>+ 120 000</b><span>prestataires vérifiés</span></div>
        <div class="auth-stat"><b>4,8<em>/5</em></b><span>note moyenne</span></div>
        <div class="auth-stat"><b>0 %</b><span>de commission</span></div>
      </div>

      <figure class="auth-brand__quote">
        <span class="auth-avatar auth-avatar--safran">SM</span>
        <p>&ldquo;J'ai trouvé mon plombier en une soirée, devis le lendemain, chantier impeccable.&rdquo; — <b>Sophie M., Lyon</b></p>
      </figure>
    </aside>

    <main class="auth-panel">
      <div class="auth-card">
        <div id="etat-formulaire">
          <a href="connexion.html" class="auth-back"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 6l-6 6 6 6"/></svg>Retour à la connexion</a>
          <div class="auth-card__header">
            <h2>Mot de passe oublié ?</h2>
            <p>Saisissez l'e-mail associé à votre compte. Nous vous enverrons un lien de réinitialisation valable 1 heure.</p>
          </div>

          <form action="#" method="post" novalidate id="formulaire-oubli">
            <div class="auth-field">
              <label class="form-label" for="email">Adresse e-mail</label>
              <div class="auth-input-group">
                <span class="auth-input-group__icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 6 10-6"/></svg></span>
                <input type="email" class="form-control" id="email" name="email" placeholder="vous@exemple.fr" autocomplete="username" required autofocus>
              </div>
            </div>
            <button class="btn-auth-primary" type="submit">Envoyer le lien de réinitialisation <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg></button>
          </form>

          <p class="auth-card__footer">Vous vous en souvenez finalement ? <a href="connexion.html">Se connecter</a></p>
        </div>

        <div class="auth-success d-none" id="etat-succes" role="status">
          <span class="auth-success__icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg></span>
          <h2>Vérifiez votre boîte mail</h2>
          <p>Si un compte existe pour <b id="email-affiche"></b>, vous recevrez un lien de réinitialisation d'ici quelques minutes.<br>Pensez à vérifier vos courriers indésirables.</p>
          <a href="connexion.html" class="btn-auth-primary mt-3" style="text-decoration:none"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 6l-6 6 6 6"/></svg>Retour à la connexion</a>
          <p class="auth-card__footer">Rien reçu ? <a href="#" onclick="location.reload();return false;">Renvoyer le lien</a></p>
        </div>
      </div>

      <p class="auth-legal"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-3.5 8-10V5l-8-3-8 3v7c0 6.5 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>Pour votre sécurité, nous ne confirmons jamais si une adresse existe dans notre base.</p>
    </main>
  </div>

<script>
// ---------- Sélecteur de profil ----------
document.querySelectorAll('.auth-switch').forEach(sw => {
  sw.querySelectorAll('.auth-switch__option').forEach(btn => btn.addEventListener('click', () => {
    sw.querySelectorAll('.auth-switch__option').forEach(b => b.setAttribute('aria-pressed', b === btn ? 'true' : 'false'));
    sw.dataset.profil = btn.dataset.choix;
    document.dispatchEvent(new CustomEvent('profil:change', { detail: btn.dataset.choix }));
  }));
});

// ---------- Afficher / masquer le mot de passe ----------
document.querySelectorAll('.auth-input-group__toggle').forEach(t => t.addEventListener('click', () => {
  const champ = t.closest('.auth-input-group').querySelector('input');
  const visible = champ.type === 'text';
  champ.type = visible ? 'password' : 'text';
  t.setAttribute('aria-label', visible ? 'Afficher le mot de passe' : 'Masquer le mot de passe');
}));

// ---------- Détection Verr. Maj ----------
document.querySelectorAll('input[type="password"]').forEach(champ => {
  champ.addEventListener('keyup', e => {
    const alerte = champ.closest('.auth-field') ? champ.closest('.auth-field').querySelector('.auth-capslock') : null;
    if (alerte && e.getModifierState) alerte.classList.toggle('is-visible', e.getModifierState('CapsLock'));
  });
});

// ---------- Bascule vers l'état « lien envoyé » ----------
document.getElementById('formulaire-oubli').addEventListener('submit', e => {
  e.preventDefault();
  const email = document.getElementById('email').value.trim();
  if (!email) return;
  document.getElementById('email-affiche').textContent = email;
  document.getElementById('etat-formulaire').classList.add('d-none');
  document.getElementById('etat-succes').classList.remove('d-none');
});

</script>
</body>
</html>
