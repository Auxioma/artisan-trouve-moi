<script>
// ---------- Sélecteur de profil ----------
document.querySelectorAll('.auth-switch').forEach(sw => {
  sw.querySelectorAll('.auth-switch__option').forEach(btn => btn.addEventListener('click', () => {
    sw.querySelectorAll('.auth-switch__option').forEach(b => b.setAttribute('aria-pressed', b === btn ? 'true' : 'false'));
    sw.dataset.profil = btn.dataset.choix;
    document.dispatchEvent(new CustomEvent('profil:change', { detail: btn.dataset.choix }));
  }));
});

// ---------- Afficher / masquer le mot de passe ----------
document.querySelectorAll('.auth-input-group__toggle').forEach(t => t.addEventListener('click', () => {
  const champ = t.closest('.auth-input-group').querySelector('input');
  const visible = champ.type === 'text';
  champ.type = visible ? 'password' : 'text';
  t.setAttribute('aria-label', visible ? 'Afficher le mot de passe' : 'Masquer le mot de passe');
}));

// ---------- Détection Verr. Maj ----------
document.querySelectorAll('input[type="password"]').forEach(champ => {
  champ.addEventListener('keyup', e => {
    const alerte = champ.closest('.auth-field') ? champ.closest('.auth-field').querySelector('.auth-capslock') : null;
    if (alerte && e.getModifierState) alerte.classList.toggle('is-visible', e.getModifierState('CapsLock'));
  });
});

// ---------- Jauge de robustesse + règles ----------
const champMdp = document.getElementById('mot-de-passe');
if (champMdp) {
  const jauge = document.querySelector('.auth-strength');
  const label = jauge ? jauge.querySelector('.auth-strength__label') : null;
  const libelles = ['', 'Faible', 'Moyen', 'Bon', 'Excellent'];
  const regles = {
    longueur: v => v.length >= 8,
    majuscule: v => /[A-ZÀ-Ý]/.test(v),
    chiffre: v => /\d/.test(v),
    special: v => /[^A-Za-z0-9À-ÿ]/.test(v),
  };
  champMdp.addEventListener('input', () => {
    const v = champMdp.value;
    let score = 0;
    Object.entries(regles).forEach(([nom, test]) => {
      const ok = test(v);
      if (ok) score++;
      const item = document.querySelector(`[data-regle="${nom}"]`);
      if (item) item.classList.toggle('is-valid', ok);
    });
    if (jauge) jauge.dataset.niveau = v ? score : 0;
    if (label) label.textContent = v ? libelles[score] : '';
  });
}

// ---------- Confirmation ----------
const conf = document.getElementById('confirmation');
const err = document.getElementById('erreur-confirmation');
if (conf) conf.addEventListener('input', () => {
  const differe = conf.value && conf.value !== document.getElementById('mot-de-passe').value;
  conf.classList.toggle('is-invalid', differe);
  err.style.display = differe ? 'flex' : 'none';
});

</script>
