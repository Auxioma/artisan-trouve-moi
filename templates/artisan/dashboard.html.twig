              <div class="ligne-demande__fin">
                <span class="ligne-demande__quand d-none d-sm-inline">Hier</span>
                <span class="chip chip--repondue">RÉPONDUE</span>
                <span class="ligne-demande__chevron"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 6 6 6-6 6"/></svg></span>
              </div>
            </div>
            <div class="ligne-demande">
              <div><b>Remplacement robinetterie cuisine</b><p>Lyon 6e — Budget < 300 €</p></div>
              <div class="ligne-demande__fin">
                <span class="ligne-demande__quand d-none d-sm-inline">Hier</span>
                <span class="chip chip--repondue">RÉPONDUE</span>
                <span class="ligne-demande__chevron"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 6 6 6-6 6"/></svg></span>
              </div>
            </div>
            <div class="ligne-demande">
              <div><b>Débouchage canalisation</b><p>Lyon 8e — Colonne d'immeuble</p></div>
              <div class="ligne-demande__fin">
                <span class="ligne-demande__quand d-none d-sm-inline">12/05</span>
                <span class="chip chip--repondue">RÉPONDUE</span>
                <span class="ligne-demande__chevron"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 6 6 6-6 6"/></svg></span>
              </div>
            </div>
        </section>

        <section class="dash-card">
          <div class="dash-card__header">
