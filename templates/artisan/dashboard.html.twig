            </div>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-4 col-xxl-2">
          <div class="kpi">
            <span class="kpi__icone kpi__icone--safran"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 3H6v18h12V8z"/><path d="M13 3v5h5M9 13h6M9 17h4"/></svg></span>
            <div>
              <div class="kpi__valeur">8</div>
              <div class="kpi__libelle">Devis en attente</div>
              <span class="kpi__delta"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 17 6-6 4 4 8-8"/><path d="M14 7h7v7"/></svg>+ 2 depuis hier</span>
            </div>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-4 col-xxl-2">
          <div class="kpi">
            <span class="kpi__icone kpi__icone--vert"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 20h20M4 20V9l8-6 8 6v11"/><path d="M9 20v-6h6v6"/></svg></span>
            <div>
              <div class="kpi__valeur">5</div>
              <div class="kpi__libelle">Chantiers en cours</div>
              <span class="kpi__delta kpi__delta--neutre">= stable</span>
            </div>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-4 col-xxl-2">
          <div class="kpi">
            <span class="kpi__icone kpi__icone--or"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z"/></svg></span>
            <div>
