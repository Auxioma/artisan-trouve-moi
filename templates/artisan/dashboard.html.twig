              <option selected>12 derniers jours</option>
              <option>30 derniers jours</option>
            </select>
          </div>
          <div class="perf-stats">
            <div><h3>Vues</h3><b>248</b><small>+ 18 %</small></div>
            <div><h3>Demandes</h3><b>32</b><small>+ 12 %</small></div>
            <div><h3>Devis envoyés</h3><b>18</b><small>+ 8 %</small></div>
            <div><h3>Conversion</h3><b>28 %</b><small>+ 6 %</small></div>
          </div>
          <svg viewBox="-4 -4 352 100" class="w-100 d-block" role="img" aria-label="Évolution des vues, demandes et devis sur 12 jours" xmlns="http://www.w3.org/2000/svg">
              <line x1="0" y1="56" x2="340" y2="56" stroke="#EEF1F7" stroke-width="1"/><line x1="0" y1="39" x2="340" y2="39" stroke="#EEF1F7" stroke-width="1"/><line x1="0" y1="22" x2="340" y2="22" stroke="#EEF1F7" stroke-width="1"/><line x1="0" y1="6" x2="340" y2="6" stroke="#EEF1F7" stroke-width="1"/>
