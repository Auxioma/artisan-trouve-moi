              <polyline points="4.0,63.2 34.2,56.6 64.4,52.2 94.5,54.4 124.7,50.0 154.9,53.3 185.1,47.8 215.3,52.2 245.5,45.6 275.6,50.0 305.8,43.4 336.0,47.8" fill="none" stroke="#0E9F6E" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>
              <polyline points="4.0,68.7 34.2,65.4 64.4,63.2 94.5,64.3 124.7,62.1 154.9,63.2 185.1,59.9 215.3,62.1 245.5,58.8 275.6,61.0 305.8,56.6 336.0,59.9" fill="none" stroke="#7C3AED" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>
              <text x="4" y="90" font-size="8" fill="#98A6C3" text-anchor="middle" font-family="Inter,sans-serif">10/05</text><text x="70" y="90" font-size="8" fill="#98A6C3" text-anchor="middle" font-family="Inter,sans-serif">12/05</text><text x="137" y="90" font-size="8" fill="#98A6C3" text-anchor="middle" font-family="Inter,sans-serif">14/05</text><text x="203" y="90" font-size="8" fill="#98A6C3" text-anchor="middle" font-family="Inter,sans-serif">16/05</text><text x="270" y="90" font-size="8" fill="#98A6C3" text-anchor="middle" font-family="Inter,sans-serif">18/05</text><text x="336" y="90" font-size="8" fill="#98A6C3" text-anchor="middle" font-family="Inter,sans-serif">20/05</text>
            </svg>
          <div class="perf-legende">
