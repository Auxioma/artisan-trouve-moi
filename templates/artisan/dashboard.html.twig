            </div>
          </div>
          <p class="small fw-bold text-dark mb-2">Aujourd'hui — jeudi 16 mai</p>
          <div class="rdv">
            <b>14:00 · Rendez-vous chantier</b>
            <p>Rénovation salle de bain — Sophie Martin, Lyon 3e</p>
          </div>
          <a href="#" class="dash-card__lien d-inline-flex align-items-center gap-2 mt-3">Voir le détail <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
        </section>

        <section class="dash-card">
          <div class="dash-card__header">
            <h2>Mes tâches</h2>
            <button class="btn btn-dash-ghost btn-sm" type="button" aria-label="Ajouter une tâche"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg></button>
          </div>
            <label class="tache">
              <input class="form-check-input mt-0" type="checkbox">
              <div><b>Répondre à 3 nouvelles demandes</b><p class="urgent"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18h6M10 21h4"/><path d="M12 3a6 6 0 0 0-3.5 10.9c.9.7 1.5 1.3 1.5 2.1h4c0-.8.6-1.4 1.5-2.1A6 6 0 0 0 12 3z"/></svg>Priorité haute</p></div>
            </label>
            <label class="tache">
              <input class="form-check-input mt-0" type="checkbox">
              <div><b>Établir le devis — fuite d'eau Villeurbanne</b><p class=""><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>Aujourd'hui</p></div>
            </label>
            <label class="tache">
