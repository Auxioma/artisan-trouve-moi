{% block javascripts %}
{{ parent() }}
<script>
// ============ Filtrage par onglet + recherche ============
const onglets = document.querySelectorAll('.tabs-statut__onglet');
const lignes = document.querySelectorAll('#corps-devis tr[data-statut]');
const champRecherche = document.getElementById('recherche-devis');
const ligneVide = document.getElementById('ligne-vide');
let filtreActif = 'tout';

function appliquerFiltres() {
  const terme = champRecherche.value.trim().toLowerCase();
  let visibles = 0;
  lignes.forEach(l => {
    const okStatut = filtreActif === 'tout' || l.dataset.statut === filtreActif;
    const okTexte = !terme || l.dataset.texte.includes(terme);
    const visible = okStatut && okTexte;
    l.classList.toggle('d-none', !visible);
    if (visible) visibles++;
  });
  ligneVide.classList.toggle('d-none', visibles > 0);
}

onglets.forEach(o => o.addEventListener('click', () => {
  onglets.forEach(x => { x.classList.toggle('actif', x === o); x.setAttribute('aria-selected', x === o); });
  filtreActif = o.dataset.filtre;
  appliquerFiltres();
}));

champRecherche.addEventListener('input', appliquerFiltres);
</script>
{% endblock %}
