{% extends 'artisan/base_artisan.html.twig' %}

{% set menu_actif = 'devis' %}

{% block title %}Mes devis{% endblock %}

{% block body %}

    <!-- En-tête -->
    <div class="dash-header">
      <div>
        <h1>Mes devis</h1>
        <p>4 devis en attente de réponse — 2 expirent dans moins de 3 jours.</p>
      </div>
      <div class="dash-header__actions">
        <button class="btn btn-dash-ghost" type="button"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12M8 7l4-4 4 4"/><path d="M4 17v3a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-3"/></svg>Exporter</button>
        <button class="btn btn-dash-primary" type="button"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>Créer un devis</button>
      </div>
    </div>

    <!-- KPI -->
    <div class="row g-3 mb-4">
      <div class="col-6 col-lg-3">
        <div class="kpi">
          <span class="kpi__icone kpi__icone--bleu"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 3H6v18h12V8z"/><path d="M13 3v5h5M9 13h6M9 17h4"/></svg></span>
          <div>
            <div class="kpi__valeur">18</div>
            <div class="kpi__libelle">Devis envoyés ce mois</div>
            <span class="kpi__delta"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 17 6-6 4 4 8-8"/><path d="M14 7h7v7"/></svg>+ 4 vs avril</span>
          </div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="kpi">
          <span class="kpi__icone kpi__icone--safran"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg></span>
          <div>
            <div class="kpi__valeur">4</div>
            <div class="kpi__libelle">En attente de réponse</div>
            <span class="kpi__delta kpi__delta--neutre">2 expirent bientôt</span>
          </div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="kpi">
          <span class="kpi__icone kpi__icone--vert"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg></span>
          <div>
            <div class="kpi__valeur">62 %</div>
            <div class="kpi__libelle">Taux d'acceptation</div>
            <span class="kpi__delta"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 17 6-6 4 4 8-8"/><path d="M14 7h7v7"/></svg>+ 6 pts vs avril</span>
          </div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="kpi">
          <span class="kpi__icone kpi__icone--violet"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2.5"/><path d="M6 12h.01M18 12h.01"/></svg></span>
          <div>
            <div class="kpi__valeur">18 560 €</div>
            <div class="kpi__libelle">Montant accepté (mois)</div>
            <span class="kpi__delta"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 17 6-6 4 4 8-8"/><path d="M14 7h7v7"/></svg>+ 16 % vs avril</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Onglets de statut -->
    <div class="tabs-statut" role="tablist" aria-label="Filtrer par statut">
      <button class="tabs-statut__onglet actif" type="button" data-filtre="tout" role="tab" aria-selected="true">Tous <span class="tabs-statut__compteur">9</span></button>
      <button class="tabs-statut__onglet" type="button" data-filtre="brouillon" role="tab" aria-selected="false">Brouillons <span class="tabs-statut__compteur">1</span></button>
      <button class="tabs-statut__onglet" type="button" data-filtre="attente" role="tab" aria-selected="false">En attente <span class="tabs-statut__compteur">4</span></button>
      <button class="tabs-statut__onglet" type="button" data-filtre="accepte" role="tab" aria-selected="false">Acceptés <span class="tabs-statut__compteur">2</span></button>
      <button class="tabs-statut__onglet" type="button" data-filtre="refuse" role="tab" aria-selected="false">Refusés <span class="tabs-statut__compteur">1</span></button>
      <button class="tabs-statut__onglet" type="button" data-filtre="expire" role="tab" aria-selected="false">Expirés <span class="tabs-statut__compteur">1</span></button>
    </div>

    <!-- Filtres -->
    <div class="filtres">
      <div class="filtres__recherche">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
        <input type="search" id="recherche-devis" placeholder="Rechercher par n°, client, ville ou prestation…" aria-label="Rechercher dans les devis">
      </div>
      <select class="form-select" aria-label="Filtrer par période">
        <option>30 derniers jours</option>
        <option>Ce mois-ci</option>
        <option>3 derniers mois</option>
        <option>Année 2024</option>
      </select>
      <select class="form-select" aria-label="Trier">
        <option>Plus récents d'abord</option>
        <option>Montant décroissant</option>
        <option>Montant croissant</option>
        <option>Expiration proche d'abord</option>
      </select>
    </div>

    <!-- Tableau -->
    <div class="tableau-wrap">
      <table class="table-devis">
        <thead>
          <tr>
            <th scope="col">N° devis</th>
            <th scope="col">Client</th>
            <th scope="col">Prestation</th>
            <th scope="col">Montant TTC</th>
            <th scope="col">Envoyé</th>
            <th scope="col">Validité</th>
            <th scope="col">Statut</th>
            <th scope="col" class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody id="corps-devis">
            <tr data-statut="brouillon" data-texte="dev-2024-058 sophie martin lyon 3e rénovation complète salle de bain 6 m²">
