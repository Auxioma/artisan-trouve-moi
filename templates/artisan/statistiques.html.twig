{% extends 'artisan/base_artisan.html.twig' %}

{% set menu_actif = 'statistiques' %}

{% block title %}Statistiques{% endblock %}

{% block body %}

    <div class="dash-header">
      <div>
        <h1>Statistiques</h1>
        <p>Vue d'ensemble de votre activité — mise à jour aujourd'hui à 06 h 00.</p>
      </div>
      <div class="dash-header__actions">
        <select class="form-select w-auto" aria-label="Période">
          <option>30 derniers jours</option>
          <option selected>6 derniers mois</option>
          <option>12 derniers mois</option>
        </select>
        <button class="btn btn-dash-ghost" type="button"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12M8 7l4-4 4 4"/><path d="M4 17v3a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-3"/></svg>Exporter</button>
      </div>
    </div>

    <div class="row g-3 mb-4">
      <div class="col-6 col-lg-3">
        <div class="kpi">
          <span class="kpi__icone kpi__icone--bleu"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg></span>
          <div>
            <div class="kpi__valeur">1 284</div>
            <div class="kpi__libelle">Vues du profil (6 mois)</div>
            <span class="kpi__delta"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 17 6-6 4 4 8-8"/><path d="M14 7h7v7"/></svg>+ 18 % vs période préc.</span>
          </div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="kpi">
          <span class="kpi__icone kpi__icone--safran"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 3H6v18h12V8z"/><path d="M13 3v5h5M9 13h6M9 17h4"/></svg></span>
          <div>
            <div class="kpi__valeur">96</div>
            <div class="kpi__libelle">Devis envoyés</div>
            <span class="kpi__delta"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 17 6-6 4 4 8-8"/><path d="M14 7h7v7"/></svg>+ 12 %</span>
          </div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="kpi">
          <span class="kpi__icone kpi__icone--vert"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg></span>
          <div>
            <div class="kpi__valeur">62 %</div>
            <div class="kpi__libelle">Taux d’acceptation</div>
            <span class="kpi__delta"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 17 6-6 4 4 8-8"/><path d="M14 7h7v7"/></svg>+ 6 pts</span>
          </div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="kpi">
          <span class="kpi__icone kpi__icone--violet"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2.5"/><path d="M6 12h.01M18 12h.01"/></svg></span>
          <div>
            <div class="kpi__valeur">64 600 €</div>
            <div class="kpi__libelle">Chiffre d’affaires</div>
            <span class="kpi__delta"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 17 6-6 4 4 8-8"/><path d="M14 7h7v7"/></svg>+ 21 %</span>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-12 col-xl-8 d-grid gap-3 align-content-start">
        <section class="dash-card">
          <div class="dash-card__header"><h2>Vues du profil</h2><span class="chip chip--en-cours">248 en mai</span></div>
          <div class="graph-wrap"><svg viewBox="0 0 720 190" role="img" aria-label="Évolution des vues du profil sur 6 mois" xmlns="http://www.w3.org/2000/svg">
              <defs><linearGradient id="deg-vues" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#1E49C7" stop-opacity=".22"/><stop offset="100%" stop-color="#1E49C7" stop-opacity="0"/></linearGradient></defs>
              <line x1="8" y1="162" x2="712" y2="162" stroke="#EEF1F7"/><line x1="8" y1="126" x2="712" y2="126" stroke="#EEF1F7"/><line x1="8" y1="91" x2="712" y2="91" stroke="#EEF1F7"/><line x1="8" y1="55" x2="712" y2="55" stroke="#EEF1F7"/><line x1="8" y1="20" x2="712" y2="20" stroke="#EEF1F7"/>
              <polygon points="8.0,139.1 72.0,119.3 136.0,130.6 200.0,98.0 264.0,107.9 328.0,71.1 392.0,83.8 456.0,93.7 520.0,79.6 584.0,54.0 648.0,64.0 712.0,37.0 712,176 8,176" fill="url(#deg-vues)"/>
              <polyline points="8.0,139.1 72.0,119.3 136.0,130.6 200.0,98.0 264.0,107.9 328.0,71.1 392.0,83.8 456.0,93.7 520.0,79.6 584.0,54.0 648.0,64.0 712.0,37.0" fill="none" stroke="#1E49C7" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/>
              <circle cx="712" cy="37.0" r="4" fill="#1E49C7"/>
              <text x="8" y="189" font-size="9" fill="#98A6C3" text-anchor="middle" font-family="Inter,sans-serif">Déc</text><text x="149" y="189" font-size="9" fill="#98A6C3" text-anchor="middle" font-family="Inter,sans-serif">Jan</text><text x="290" y="189" font-size="9" fill="#98A6C3" text-anchor="middle" font-family="Inter,sans-serif">Fév</text><text x="430" y="189" font-size="9" fill="#98A6C3" text-anchor="middle" font-family="Inter,sans-serif">Mar</text><text x="571" y="189" font-size="9" fill="#98A6C3" text-anchor="middle" font-family="Inter,sans-serif">Avr</text><text x="712" y="189" font-size="9" fill="#98A6C3" text-anchor="middle" font-family="Inter,sans-serif">Mai</text>
            </svg></div>
        </section>

        <div class="row g-3">
          <div class="col-12 col-md-6">
            <section class="dash-card h-100">
              <div class="dash-card__header"><h2>Chiffre d'affaires</h2></div>
              <div class="graph-wrap"><svg viewBox="0 0 340 170" role="img" aria-label="Chiffre d'affaires des 6 derniers mois" xmlns="http://www.w3.org/2000/svg"><rect x="14" y="81" width="32" height="67" rx="6" fill="#1E49C7"/><text x="30" y="162" font-size="9" fill="#98A6C3" text-anchor="middle" font-family="Inter,sans-serif">Déc</text><text x="30" y="75" font-size="8.5" font-weight="700" fill="#233047" text-anchor="middle" font-family="Inter,sans-serif">8.2 k</text><rect x="67" y="72" width="32" height="76" rx="6" fill="#1E49C7"/><text x="83" y="162" font-size="9" fill="#98A6C3" text-anchor="middle" font-family="Inter,sans-serif">Jan</text><text x="83" y="66" font-size="8.5" font-weight="700" fill="#233047" text-anchor="middle" font-family="Inter,sans-serif">9.4 k</text><rect x="121" y="85" width="32" height="63" rx="6" fill="#1E49C7"/><text x="137" y="162" font-size="9" fill="#98A6C3" text-anchor="middle" font-family="Inter,sans-serif">Fév</text><text x="137" y="79" font-size="8.5" font-weight="700" fill="#233047" text-anchor="middle" font-family="Inter,sans-serif">7.8 k</text><rect x="174" y="57" width="32" height="91" rx="6" fill="#1E49C7"/><text x="190" y="162" font-size="9" fill="#98A6C3" text-anchor="middle" font-family="Inter,sans-serif">Mar</text><text x="190" y="51" font-size="8.5" font-weight="700" fill="#233047" text-anchor="middle" font-family="Inter,sans-serif">11.2 k</text><rect x="227" y="46" width="32" height="102" rx="6" fill="#1E49C7"/><text x="243" y="162" font-size="9" fill="#98A6C3" text-anchor="middle" font-family="Inter,sans-serif">Avr</text><text x="243" y="40" font-size="8.5" font-weight="700" fill="#233047" text-anchor="middle" font-family="Inter,sans-serif">12.6 k</text><rect x="281" y="22" width="32" height="126" rx="6" fill="#FF8A1E"/><text x="297" y="162" font-size="9" fill="#98A6C3" text-anchor="middle" font-family="Inter,sans-serif">Mai</text><text x="297" y="16" font-size="8.5" font-weight="700" fill="#233047" text-anchor="middle" font-family="Inter,sans-serif">15.5 k</text></svg></div>
            </section>
          </div>
          <div class="col-12 col-md-6">
            <section class="dash-card h-100">
              <div class="dash-card__header"><h2>Entonnoir de conversion</h2></div>
              <div class="entonnoir">
                <div class="entonnoir__etape">
                  <div class="entonnoir__haut"><b>Vues du profil</b><span class="val">1 284</span></div>
                  <div class="entonnoir__rail"><i class="p-100"></i></div>
                </div>
                <div class="entonnoir__etape">
                  <div class="entonnoir__haut"><b>Demandes reçues</b><span class="taux">18 %</span><span class="val">231</span></div>
                  <div class="entonnoir__rail"><i class="p-65"></i></div>
                </div>
                <div class="entonnoir__etape">
                  <div class="entonnoir__haut"><b>Devis envoyés</b><span class="taux">42 %</span><span class="val">96</span></div>
                  <div class="entonnoir__rail"><i class="p-45"></i></div>
                </div>
                <div class="entonnoir__etape">
                  <div class="entonnoir__haut"><b>Devis acceptés</b><span class="taux">62 %</span><span class="val">59</span></div>
                  <div class="entonnoir__rail"><i class="p-30"></i></div>
                </div>
              </div>
            </section>
          </div>
        </div>
      </div>

      <div class="col-12 col-xl-4 d-grid gap-3 align-content-start">
        <section class="dash-card">
          <div class="dash-card__header"><h2>Répartition du CA</h2></div>
          <div class="row g-3 align-items-center">
            <div class="col-5"><svg viewBox="0 0 140 140" role="img" aria-label="Répartition du chiffre d'affaires par prestation" xmlns="http://www.w3.org/2000/svg">
            <circle cx="70" cy="70" r="54" fill="none" stroke="#1E49C7" stroke-width="18" stroke-dasharray="115.4 223.9" stroke-dashoffset="0.0" transform="rotate(-90 70 70)"/><circle cx="70" cy="70" r="54" fill="none" stroke="#0E9F6E" stroke-width="18" stroke-dasharray="88.2 251.1" stroke-dashoffset="-115.4" transform="rotate(-90 70 70)"/><circle cx="70" cy="70" r="54" fill="none" stroke="#FF8A1E" stroke-width="18" stroke-dasharray="74.6 264.6" stroke-dashoffset="-203.6" transform="rotate(-90 70 70)"/><circle cx="70" cy="70" r="54" fill="none" stroke="#7C3AED" stroke-width="18" stroke-dasharray="37.3 302.0" stroke-dashoffset="-278.2" transform="rotate(-90 70 70)"/><circle cx="70" cy="70" r="54" fill="none" stroke="#98A6C3" stroke-width="18" stroke-dasharray="23.8 315.5" stroke-dashoffset="-315.5" transform="rotate(-90 70 70)"/>
            <text x="70" y="66" font-size="19" font-weight="800" fill="#0A1633" text-anchor="middle" font-family="Bricolage Grotesque,Inter,sans-serif">64,6 k€</text>
            <text x="70" y="82" font-size="8.5" fill="#5B6B85" text-anchor="middle" font-family="Inter,sans-serif">CA 6 mois</text>
          </svg></div>
            <div class="col-7"><div class="donut-legende">
            <span><i class="donut-c-0"></i>Salle de bain / sanitaires<b>34 %</b></span>
            <span><i class="donut-c-1"></i>Dépannage / fuites<b>26 %</b></span>
            <span><i class="donut-c-2"></i>Chauffage / chauffe-eau<b>22 %</b></span>
            <span><i class="donut-c-3"></i>Débouchage<b>11 %</b></span>
            <span><i class="donut-c-4"></i>Autres<b>7 %</b></span>
            </div></div>
          </div>
        </section>

        <section class="dash-card">
          <div class="dash-card__header"><h2>Top prestations</h2></div>
            <div class="rang"><span class="rang__pos">1</span><div><b>Rénovation salle de bain</b><span>14 chantiers · 6 mois</span></div><span class="rang__ca">21 900 €</span></div>
            <div class="rang"><span class="rang__pos">2</span><div><b>Chauffe-eau / chauffage</b><span>18 interventions</span></div><span class="rang__ca">14 200 €</span></div>
            <div class="rang"><span class="rang__pos">3</span><div><b>Dépannages & fuites</b><span>42 interventions</span></div><span class="rang__ca">12 400 €</span></div>
            <div class="rang"><span class="rang__pos">4</span><div><b>Débouchage</b><span>23 interventions</span></div><span class="rang__ca">7 100 €</span></div>
            <div class="rang"><span class="rang__pos">5</span><div><b>Robinetterie & petits travaux</b><span>31 interventions</span></div><span class="rang__ca">5 300 €</span></div>
        </section>

        <section class="dash-card">
          <div class="dash-card__header"><h2>Réputation</h2></div>
          <div class="row g-2 text-center">
            <div class="col-4"><div class="kpi__valeur">4,8</div><div class="kpi__libelle">Note moyenne</div></div>
            <div class="col-4"><div class="kpi__valeur">256</div><div class="kpi__libelle">Avis reçus</div></div>
            <div class="col-4"><div class="kpi__valeur">1 h 45</div><div class="kpi__libelle">Tps de réponse</div></div>
          </div>
        </section>
      </div>
    </div>

{% endblock %}
