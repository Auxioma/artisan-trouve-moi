{% extends 'artisan/base_artisan.html.twig' %}

{% set menu_actif = 'messages' %}

{% block title %}Messages{% endblock %}

{% block body %}

    <div class="dash-header">
      <div>
        <h1>Messages</h1>
        <p>2 conversations non lues — temps de réponse moyen : 1 h 45.</p>
      </div>
    </div>

    <div class="msg-layout" id="msg-layout">

      <!-- Liste des conversations -->
      <aside class="msg-liste">
        <div class="msg-liste__entete">
          <div class="filtres__recherche">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
            <input type="search" placeholder="Rechercher une conversation…" aria-label="Rechercher une conversation">
          </div>
        </div>
        <div class="msg-liste__scroll">
          <button class="conversation actif non-lu" type="button">
            <span class="avatar avatar--safran">SM</span>
            <span class="conversation__corps">
              <span class="conversation__haut"><b>Sophie Martin</b><span class="conversation__quand">10:30</span></span>
              <span class="conversation__sujet">Rénovation salle de bain — Lyon 3e</span>
              <p class="conversation__apercu">Parfait, je vous confirme le rendez-vous de demain 14 h.</p>
            </span>
            <span class="conversation__pastille">1</span>
          </button>
          <button class="conversation non-lu" type="button">
            <span class="avatar avatar--bleu">MD</span>
            <span class="conversation__corps">
              <span class="conversation__haut"><b>Michel Dupont</b><span class="conversation__quand">09:12</span></span>
              <span class="conversation__sujet">Fuite d'eau — Villeurbanne</span>
              <p class="conversation__apercu">Merci pour votre réactivité, voici les photos sous l'évier…</p>
            </span>
            <span class="conversation__pastille">2</span>
          </button>
          <button class="conversation" type="button">
            <span class="avatar avatar--vert">NK</span>
            <span class="conversation__corps">
              <span class="conversation__haut"><b>Nadia Karim</b><span class="conversation__quand">Hier</span></span>
              <span class="conversation__sujet">Salle d'eau studio — Bron</span>
              <p class="conversation__apercu">Le carrelage livré ce matin correspond bien à la référence.</p>
            </span>
            
          </button>
          <button class="conversation" type="button">
            <span class="avatar avatar--violet">CP</span>
            <span class="conversation__corps">
              <span class="conversation__haut"><b>Camille Petit · Syndic</b><span class="conversation__quand">Hier</span></span>
              <span class="conversation__sujet">Colonne d'évacuation — Lyon 8e</span>
              <p class="conversation__apercu">L'accès aux caves sera ouvert dès 8 h lundi.</p>
            </span>
            
          </button>
          <button class="conversation" type="button">
            <span class="avatar avatar--encre">JM</span>
            <span class="conversation__corps">
              <span class="conversation__haut"><b>Julien Moreau</b><span class="conversation__quand">15/05</span></span>
              <span class="conversation__sujet">Robinetterie cuisine — Lyon 6e</span>
              <p class="conversation__apercu">Tout fonctionne parfaitement, merci encore !</p>
            </span>
            
          </button>
          <button class="conversation" type="button">
            <span class="avatar avatar--bleu">TL</span>
            <span class="conversation__corps">
              <span class="conversation__haut"><b>Thomas Legrand</b><span class="conversation__quand">14/05</span></span>
              <span class="conversation__sujet">Entretien chaudière — Caluire</span>
              <p class="conversation__apercu">Bien reçu le certificat, bonne journée.</p>
            </span>
            
          </button>
        </div>
      </aside>

      <!-- Fil de discussion -->
      <section class="msg-fil" aria-label="Conversation avec Sophie Martin">
        <div class="msg-fil__entete">
          <button class="btn-icone msg-fil__retour" type="button" id="btn-retour" aria-label="Retour aux conversations"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 6-6 6 6 6"/></svg></button>
          <span class="avatar avatar--safran">SM</span>
          <div>
            <b>Sophie Martin</b>
            <span>Rénovation salle de bain — Lyon 3e · <span class="en-ligne">En ligne</span></span>
          </div>
          <div class="msg-fil__actions">
            <button class="btn-icone" type="button" aria-label="Appeler"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.7A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 2 .7 2.8a2 2 0 0 1-.4 2.1L8 10a16 16 0 0 0 6 6l1.4-1.4a2 2 0 0 1 2.1-.4c.9.3 1.8.5 2.8.7a2 2 0 0 1 1.7 2z"/></svg></button>
            <button class="btn-icone" type="button" aria-label="Voir la demande"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 3H6v18h12V8z"/><path d="M13 3v5h5M9 13h6M9 17h4"/></svg></button>
          </div>
        </div>

        <div class="msg-fil__scroll" id="fil-messages">
          <span class="msg-jour">Hier — 15 mai</span>

          <div class="bulle bulle--recu">
            <div class="bulle__contenu">Bonjour, j'ai bien reçu votre devis pour la salle de bain. Le montant me convient, mais serait-il possible de commencer début juin plutôt que fin mai ?</div>
            <span class="bulle__meta">17:42</span>
          </div>

          <div class="bulle bulle--envoye">
            <div class="bulle__contenu">Bonjour Madame Martin, merci pour votre retour ! Aucun souci : je vous propose un démarrage le lundi 3 juin, pour une livraison le 14 juin. Je vous renvoie le devis mis à jour.</div>
            <div class="bulle__piece"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 3H6v18h12V8z"/><path d="M13 3v5h5M9 13h6M9 17h4"/></svg><span><b>Devis DEV-2024-058 — v2.pdf</b><span>3 450,00 € TTC · 2 pages</span></span></div>
            <span class="bulle__meta">18:05 <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m2 13 4 4L14 9"/><path d="m10 13 4 4 8-8"/></svg></span>
          </div>

          <span class="msg-jour">Aujourd'hui — 16 mai</span>

          <div class="bulle bulle--recu">
            <div class="bulle__contenu">C'est parfait pour le 3 juin ! J'ai signé le devis en ligne ce matin. Est-ce qu'on garde le rendez-vous de demain 14 h pour valider les derniers détails techniques ?</div>
            <span class="bulle__meta">10:28</span>
          </div>

          <div class="bulle bulle--recu">
            <div class="bulle__contenu">Parfait, je vous confirme le rendez-vous de demain 14 h.</div>
            <span class="bulle__meta">10:30</span>
          </div>
        </div>

        <div class="msg-composeur">
          <button class="btn-icone" type="button" aria-label="Joindre un fichier"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m21 12-8.5 8.5a5 5 0 0 1-7-7L14 5a3.5 3.5 0 0 1 5 5l-8.5 8.5a2 2 0 0 1-3-3L16 7"/></svg></button>
          <textarea class="form-control" id="champ-message" rows="1" placeholder="Écrivez votre message…" aria-label="Votre message"></textarea>
          <button class="btn-envoyer" type="button" id="btn-envoyer" aria-label="Envoyer le message"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m22 2-7 20-4-9-9-4z"/><path d="M22 2 11 13"/></svg></button>
        </div>
      </section>
    </div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// ============ Composeur : envoi de message ============
const fil = document.getElementById('fil-messages');
const champ = document.getElementById('champ-message');
const btnEnvoyer = document.getElementById('btn-envoyer');

function envoyerMessage() {
  const texte = champ.value.trim();
  if (!texte) return;
  const bulle = document.createElement('div');
  bulle.className = 'bulle bulle--envoye';
  const contenu = document.createElement('div');
  contenu.className = 'bulle__contenu';
  contenu.textContent = texte;
  const meta = document.createElement('span');
  meta.className = 'bulle__meta';
  meta.textContent = new Date().toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
  bulle.append(contenu, meta);
  fil.appendChild(bulle);
  champ.value = '';
  champ.style.height = 'auto';
  fil.scrollTop = fil.scrollHeight;
}
btnEnvoyer.addEventListener('click', envoyerMessage);
champ.addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); envoyerMessage(); }
});
champ.addEventListener('input', () => {
  champ.style.height = 'auto';
  champ.style.height = Math.min(champ.scrollHeight, 110) + 'px';
});
fil.scrollTop = fil.scrollHeight;

// ============ Mobile : bascule liste / fil ============
const layout = document.getElementById('msg-layout');
document.getElementById('btn-retour').addEventListener('click', () => layout.classList.add('voir-liste'));
document.querySelectorAll('.conversation').forEach(c => c.addEventListener('click', () => {
  document.querySelectorAll('.conversation').forEach(x => x.classList.toggle('actif', x === c));
  layout.classList.remove('voir-liste');
}));
</script>
{% endblock %}
