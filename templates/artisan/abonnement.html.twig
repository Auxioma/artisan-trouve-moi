{% extends 'artisan/base_artisan.html.twig' %}

{% set menu_actif = 'abonnement' %}

{% block title %}Mon abonnement{% endblock %}

{% block body %}

    <div class="dash-header">
      <div>
        <h1>Mon abonnement</h1>
        <p>Offre Premium active — prochain renouvellement le 12 juin 2024.</p>
      </div>
    </div>

    <div class="row g-3 mb-4">
      <div class="col-12 col-lg-7">
        <div class="dash-card h-100">
          <div class="abo-actuel">
            <span class="abo-actuel__icone"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 8 4 5 5-7 5 7 4-5v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg></span>
            <div class="abo-actuel__infos">
              <b>Offre Premium</b><span class="chip chip--premium ms-2">ACTIVE</span>
              <p>Souscrite le 12/11/2023 · Renouvellement automatique le <b>12/06/2024</b></p>
            </div>
            <div class="abo-actuel__prix"><b>39 €</b><span>/ mois HT</span></div>
          </div>
          <hr class="my-3">
          <div class="row g-2 text-center">
            <div class="col-4"><div class="kpi__valeur">248</div><div class="kpi__libelle">Vues ce mois</div></div>
            <div class="col-4"><div class="kpi__valeur">12</div><div class="kpi__libelle">Demandes en avant-première</div></div>
            <div class="col-4"><div class="kpi__valeur">+ 34 %</div><div class="kpi__libelle">Visibilité vs offre Essentiel</div></div>
          </div>
        </div>
      </div>
      <div class="col-12 col-lg-5">
        <div class="dash-card h-100">
          <div class="dash-card__header"><h2>Moyen de paiement</h2></div>
          <div class="moyen-paiement">
            <span class="moyen-paiement__carte">VISA</span>
            <div><b>Visa se terminant par 4218</b><span>Expire 08/2026 · Plomberie Express SARL</span></div>
            <button class="btn btn-dash-ghost btn-sm" type="button">Modifier</button>
          </div>
          <p class="small text-secondary mt-3 mb-0">Prochain prélèvement de <b class="text-dark">46,80 € TTC</b> le 12/06/2024. Annulable à tout moment, effectif en fin de période.</p>
        </div>
      </div>
    </div>

    <h2 class="h5 mb-3 mt-2">Changer d'offre</h2>
    <div class="row g-3 mb-4 pt-2">
      <div class="col-12 col-md-4">
        <div class="plan">
          
          <span class="plan__nom">Essentiel</span>
          <p class="plan__desc">Pour démarrer et recevoir vos premières demandes.</p>
          <div class="plan__prix"><b>19 €</b><span>/ mois HT · sans engagement</span></div>
          <div class="plan__liste">
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg>Profil professionnel vérifié</span>
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg>Réception des demandes de votre zone</span>
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg>Messagerie clients illimitée</span>
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg>5 photos de réalisations</span>
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg>Devis illimités</span>
          </div>
          <button class="btn btn-dash-ghost" type="button">Passer à Essentiel</button>
        </div>
      </div>
      <div class="col-12 col-md-4">
        <div class="plan plan--actif">
          <span class="plan__badge plan__badge--actuel">VOTRE OFFRE ACTUELLE</span>
          <span class="plan__nom">Premium</span>
          <p class="plan__desc">Pour développer votre activité et gagner en visibilité.</p>
          <div class="plan__prix"><b>39 €</b><span>/ mois HT · sans engagement</span></div>
          <div class="plan__liste">
            <span class="inclus-titre">Tout Essentiel, plus :</span>
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg>Demandes en avant-première (24 h)</span>
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg>Badge « Prestataire vérifié » renforcé</span>
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg>Profil mis en avant dans votre catégorie</span>
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg>Statistiques avancées</span>
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg>30 photos de réalisations</span>
          </div>
          <button class="btn btn-dash-ghost" type="button" disabled>Votre offre actuelle</button>
        </div>
      </div>
      <div class="col-12 col-md-4">
        <div class="plan">
          <span class="plan__badge plan__badge--populaire">LE PLUS CHOISI</span>
          <span class="plan__nom">Excellence</span>
          <p class="plan__desc">Pour dominer votre secteur et maximiser vos conversions.</p>
          <div class="plan__prix"><b>69 €</b><span>/ mois HT · sans engagement</span></div>
          <div class="plan__liste">
            <span class="inclus-titre">Tout Premium, plus :</span>
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg>Position en tête de catégorie</span>
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg>Accès instantané à toutes les demandes</span>
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg>Support prioritaire 7 j/7</span>
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg>Prise de rendez-vous en ligne</span>
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg>Photos et vidéos illimitées</span>
          </div>
          <button class="btn btn-dash-primary" type="button">Passer à Excellence</button>
        </div>
      </div>
    </div>

    <div class="dash-card__header"><h2 class="h5 mb-0">Historique de facturation</h2></div>
    <div class="tableau-wrap mt-2">
      <table class="table-devis table-devis--compact">
        <thead>
          <tr>
            <th scope="col">N° facture</th>
            <th scope="col">Date</th>
            <th scope="col">Libellé</th>
            <th scope="col">Montant HT</th>
            <th scope="col">Statut</th>
            <th scope="col" class="text-end">PDF</th>
          </tr>
        </thead>
        <tbody>
            <tr>
              <td><span class="devis-ref">F-2024-0512</span></td>
              <td><span class="devis-date"><b>12/05/2024</b></span></td>
              <td><span class="devis-prestation">Abonnement Premium — mai 2024</span></td>
              <td><span class="devis-montant">39,00 €</span></td>
              <td><span class="chip chip--accepte">PAYÉE</span></td>
              <td><div class="actions-ligne"><button class="btn-icone" type="button" aria-label="Télécharger la facture F-2024-0512" title="PDF"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 3H6v18h12V8z"/><path d="M13 3v5h5M9 14h6M9 17h4"/></svg></button></div></td>
            </tr>
            <tr>
              <td><span class="devis-ref">F-2024-0412</span></td>
              <td><span class="devis-date"><b>12/04/2024</b></span></td>
              <td><span class="devis-prestation">Abonnement Premium — avril 2024</span></td>
              <td><span class="devis-montant">39,00 €</span></td>
              <td><span class="chip chip--accepte">PAYÉE</span></td>
              <td><div class="actions-ligne"><button class="btn-icone" type="button" aria-label="Télécharger la facture F-2024-0412" title="PDF"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 3H6v18h12V8z"/><path d="M13 3v5h5M9 14h6M9 17h4"/></svg></button></div></td>
            </tr>
            <tr>
              <td><span class="devis-ref">F-2024-0312</span></td>
              <td><span class="devis-date"><b>12/03/2024</b></span></td>
              <td><span class="devis-prestation">Abonnement Premium — mars 2024</span></td>
              <td><span class="devis-montant">39,00 €</span></td>
              <td><span class="chip chip--accepte">PAYÉE</span></td>
              <td><div class="actions-ligne"><button class="btn-icone" type="button" aria-label="Télécharger la facture F-2024-0312" title="PDF"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 3H6v18h12V8z"/><path d="M13 3v5h5M9 14h6M9 17h4"/></svg></button></div></td>
            </tr>
            <tr>
              <td><span class="devis-ref">F-2024-0212</span></td>
              <td><span class="devis-date"><b>12/02/2024</b></span></td>
              <td><span class="devis-prestation">Abonnement Premium — février 2024</span></td>
              <td><span class="devis-montant">39,00 €</span></td>
              <td><span class="chip chip--accepte">PAYÉE</span></td>
              <td><div class="actions-ligne"><button class="btn-icone" type="button" aria-label="Télécharger la facture F-2024-0212" title="PDF"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 3H6v18h12V8z"/><path d="M13 3v5h5M9 14h6M9 17h4"/></svg></button></div></td>
            </tr>
        </tbody>
      </table>
    </div>

    <div class="conseil mt-3">
      <p class="conseil__titre mb-0"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2 4 14h6l-1 8 9-12h-6z"/></svg>Le saviez-vous ?</p>
      <p>Les prestataires en offre Excellence reçoivent en moyenne 2,4× plus de demandes que l'offre Essentiel. Le passage est immédiat et le prorata calculé automatiquement.</p>
    </div>

{% endblock %}
