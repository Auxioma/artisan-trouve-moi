{# Sidebar prestataire — requiert : menu_actif, artisan_name, artisan_initials, demandes_count, messages_count #}
<aside class="sidebar offcanvas-lg offcanvas-start" tabindex="-1" id="sidebar" aria-label="Navigation principale">
    <div class="sidebar__profil">
      <span class="avatar avatar--lg avatar--safran">{{ artisan_initials|default('PE') }}</span>
      <div>
        <b>{{ artisan_name|default('Mon entreprise') }}</b>
        <span class="chip chip--verifie"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg>Vérifié</span>
      </div>
    </div>

    <p class="sidebar__label">Principal</p>
    <nav class="sidebar__nav" aria-label="Sections principales">
          <a href="#" class="sidebar__link"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>Tableau de bord</a>
          <a href="{{ path('app_artisan_demandes') }}" class="sidebar__link{% if menu_actif == 'demandes' %} actif{% endif %}"{% if menu_actif == 'demandes' %} aria-current="page"{% endif %}><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M8 2v4M16 2v4M7 11h10M7 15h6"/></svg>Mes demandes{% if demandes_count|default(0) > 0 %}<span class="sidebar__badge">{{ demandes_count }}</span>{% endif %}</a>
          <a href="{{ path('app_artisan_devis') }}" class="sidebar__link{% if menu_actif == 'devis' %} actif{% endif %}"{% if menu_actif == 'devis' %} aria-current="page"{% endif %}><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 3H6v18h12V8z"/><path d="M13 3v5h5M9 13h6M9 17h4"/></svg>Mes devis</a>
          <a href="{{ path('app_artisan_chantiers') }}" class="sidebar__link{% if menu_actif == 'chantiers' %} actif{% endif %}"{% if menu_actif == 'chantiers' %} aria-current="page"{% endif %}><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 20h20M4 20V9l8-6 8 6v11"/><path d="M9 20v-6h6v6"/></svg>Mes chantiers</a>
          <a href="{{ path('app_artisan_messages') }}" class="sidebar__link{% if menu_actif == 'messages' %} actif{% endif %}"{% if menu_actif == 'messages' %} aria-current="page"{% endif %}><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12a8 8 0 1 0-3.6 6.7L21 20z"/></svg>Messages{% if messages_count|default(0) > 0 %}<span class="sidebar__badge">{{ messages_count }}</span>{% endif %}</a>
          <a href="{{ path('app_artisan_avis') }}" class="sidebar__link{% if menu_actif == 'avis' %} actif{% endif %}"{% if menu_actif == 'avis' %} aria-current="page"{% endif %}><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z"/></svg>Mes avis</a>
    </nav>

    <p class="sidebar__label">Organisation</p>
    <nav class="sidebar__nav" aria-label="Organisation">
          <a href="{{ path('app_artisan_calendrier') }}" class="sidebar__link{% if menu_actif == 'calendrier' %} actif{% endif %}"{% if menu_actif == 'calendrier' %} aria-current="page"{% endif %}><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M8 3v4M16 3v4M3 10h18"/></svg>Calendrier</a>
          <a href="{{ path('app_artisan_statistiques') }}" class="sidebar__link{% if menu_actif == 'statistiques' %} actif{% endif %}"{% if menu_actif == 'statistiques' %} aria-current="page"{% endif %}><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 20V10M10 20V4M16 20v-8M22 20H2"/></svg>Statistiques</a>
    </nav>

    <p class="sidebar__label">Compte</p>
    <nav class="sidebar__nav" aria-label="Compte">
          <a href="{{ path('app_artisan_abonnement') }}" class="sidebar__link{% if menu_actif == 'abonnement' %} actif{% endif %}"{% if menu_actif == 'abonnement' %} aria-current="page"{% endif %}><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>Mon abonnement</a>
          <a href="{{ path('app_artisan_parametres') }}" class="sidebar__link{% if menu_actif == 'parametres' %} actif{% endif %}"{% if menu_actif == 'parametres' %} aria-current="page"{% endif %}><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.7 1.7 0 0 0 .3 1.9l.1.1a2 2 0 1 1-2.9 2.9l-.1-.1a1.7 1.7 0 0 0-1.9-.3 1.7 1.7 0 0 0-1 1.5V21a2 2 0 1 1-4 0v-.1a1.7 1.7 0 0 0-1-1.6 1.7 1.7 0 0 0-1.9.3l-.1.1a2 2 0 1 1-2.9-2.9l.1-.1a1.7 1.7 0 0 0 .3-1.9 1.7 1.7 0 0 0-1.5-1H3a2 2 0 1 1 0-4h.1a1.7 1.7 0 0 0 1.6-1 1.7 1.7 0 0 0-.3-1.9l-.1-.1a2 2 0 1 1 2.9-2.9l.1.1a1.7 1.7 0 0 0 1.9.3h.1a1.7 1.7 0 0 0 1-1.5V3a2 2 0 1 1 4 0v.1a1.7 1.7 0 0 0 1 1.5 1.7 1.7 0 0 0 1.9-.3l.1-.1a2 2 0 1 1 2.9 2.9l-.1.1a1.7 1.7 0 0 0-.3 1.9v.1a1.7 1.7 0 0 0 1.5 1h.2a2 2 0 1 1 0 4h-.1a1.7 1.7 0 0 0-1.5 1z"/></svg>Paramètres</a>
          <a href="{{ path('app_logout') }}" class="sidebar__link"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><path d="m16 17 5-5-5-5M21 12H9"/></svg>Déconnexion</a>
    </nav>

    <div class="sidebar__aide mt-3 mt-lg-auto">
      <b>Besoin d'aide ?</b>
      <p>Notre équipe support répond en moins de 2 h, 7 j/7.</p>
      <button class="btn-support" type="button"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 14v-2a8 8 0 0 1 16 0v2"/><rect x="2" y="14" width="5" height="6" rx="2"/><rect x="17" y="14" width="5" height="6" rx="2"/></svg> Contacter le support</button>
    </div>
  </aside>
