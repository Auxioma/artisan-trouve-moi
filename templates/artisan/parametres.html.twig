    {{ parent() }}

    <script
        src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        crossorigin=""
    ></script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            'use strict';

            /*
             * Endpoint AJAX Symfony : toute la recherche entreprise
             * + géocodage est désormais effectuée côté serveur.
             * Le SIRET est injecté dans l'URL au moment de l'appel.
             */
            /*
             * Le requirement de route est \d{14} : on génère l'URL
             * avec un SIRET factice, remplacé au moment de l'appel.
             */
            const SIRET_LOOKUP_URL_TEMPLATE =
                '{{ path('app_artisan_api_entreprise', { siret: '00000000000000' })|e('js') }}';

            const NOMINATIM_SEARCH_API =
                'https://nominatim.openstreetmap.org/search';

            const byId = (id) => document.getElementById(id);

            /*
             * Un `id` passé dans `attr` de form_widget() ne remplace
             * PAS l'id généré par Symfony (attribut dupliqué, ignoré
             * par le navigateur). On résout donc chaque champ par son
             * id "souhaité" OU, à défaut, par son name Symfony.
             */
            const pick = (id, nameSuffix) =>
                byId(id) ||
                document.querySelector(
                    `[name$="${nameSuffix}"]`
                );

            const fields = {
                legalName: pick(
                    'nom-entreprise',
                    '[artisanProfile][legalName]'
                ),
                commercialName: pick(
                    'nom-commercial',
                    '[artisanProfile][commercialName]'
                ),
                siret: pick(
                    'siret',
                    '[artisanProfile][siret]'
                ),
                apeCode: pick(
                    'ape-code',
                    '[artisanProfile][apeCode]'
                ),
                legalForm: pick(
                    'forme-juridique',
                    '[artisanProfile][legalForm]'
                ),
                vatNumber: pick(
                    'numero-tva',
                    '[artisanProfile][vatNumber]'
                ),
                addressSearch: pick(
                    'adresse-professionnelle',
                    '[artisanProfile][addressSearch]'
                ),
                city: pick(
                    'ville',
                    '[artisanProfile][city]'
                ),
                postalCode: pick(
                    'code-postal',
                    '[artisanProfile][postalCode]'
                )
            };

            /*
             * Diagnostic : signale immédiatement tout champ
             * introuvable dans le DOM.
             */
            const missingFields = Object.entries(fields)
                .filter(([, element]) => !element)
                .map(([name]) => name);

            if (missingFields.length > 0) {
                console.warn(
                    'Champs introuvables dans le DOM :',
                    missingFields
                );
            }

            const target = (name) =>
                document.querySelector(
                    `[data-osm-address-target="${name}"]`
                );

            const hiddenFields = {
                siren: target('siren'),
                houseNumber: target('houseNumber'),
                road: target('road'),
                addressComplement: document.querySelector(
                    '[name$="[artisanProfile][addressComplement]"]'
                ),
                neighbourhood: target('neighbourhood'),
                suburb: target('suburb'),
                cityDistrict: target('cityDistrict'),
                hamlet: target('hamlet'),
                village: target('village'),
                town: target('town'),
                municipality: target('municipality'),
                county: target('county'),
                stateDistrict: target('stateDistrict'),
                state: target('state'),
                region: target('region'),
                country: target('country'),
                countryCode: target('countryCode'),
                displayName: target('displayName'),
                latitude: target('latitude'),
                longitude: target('longitude'),
                osmId: target('osmId'),
                osmType: target('osmType'),
                osmCategory: target('osmCategory'),
                osmPlaceType: target('osmPlaceType'),
                nominatimPlaceId: target('nominatimPlaceId')
            };

            const companyStatus = byId('company-api-status');
            const addressStatus = byId('address-api-status');
            const verifyCompanyButton = byId('verify-company');
            const searchAddressButton = byId('search-address');
            const interventionLocation = byId('intervention-location');
            const radiusInput = pick(
                'rayon',
                '[artisanProfile][travelRadiusKm]'
            );
            const radiusValue = byId('rayon-valeur');

            let map = null;
            let marker = null;
            let circle = null;
            let lookupAbortController = null;

            const setValue = (element, value) => {
                if (!element || value === undefined || value === null) {
                    return;
                }

                element.value = String(value);
                element.dispatchEvent(
                    new Event('change', { bubbles: true })
                );
            };

            const setStatus = (element, message, type = 'secondary') => {
                if (!element) {
                    return;
                }

                element.className = `form-text mt-2 text-${type}`;
                element.textContent = message;
            };

            const normalizeSiret = (value) =>
                String(value ?? '').replace(/\D/g, '').slice(0, 14);

            const firstNonEmpty = (...values) =>
                values.find(
                    (value) =>
                        value !== undefined &&
                        value !== null &&
                        String(value).trim() !== ''
                ) ?? '';

            /*
             * ============================================================
             * CARTE LEAFLET
             * ============================================================
             */

            const initializeMap = () => {
                if (map || !window.L || !byId('intervention-map')) {
                    return;
                }

                map = L.map('intervention-map').setView(
                    [46.603354, 1.888334],
                    5
                );

                L.tileLayer(
                    'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
                    {
                        maxZoom: 19,
                        attribution:
                            '&copy; contributeurs OpenStreetMap'
                    }
                ).addTo(map);
            };

            const updateMap = (latitude, longitude) => {
                initializeMap();

                if (!map) {
                    return;
                }

                const lat = Number(latitude);
                const lon = Number(longitude);

                if (!Number.isFinite(lat) || !Number.isFinite(lon)) {
                    return;
                }

                const radiusKm = Math.max(
                    1,
                    Number(radiusInput?.value || 25)
                );

                if (marker) {
                    marker.setLatLng([lat, lon]);
                } else {
                    marker = L.marker([lat, lon]).addTo(map);
                }

                if (circle) {
                    circle.setLatLng([lat, lon]);
                    circle.setRadius(radiusKm * 1000);
                } else {
                    circle = L.circle([lat, lon], {
                        radius: radiusKm * 1000
                    }).addTo(map);
                }

                map.fitBounds(circle.getBounds(), {
                    padding: [24, 24]
                });
            };

            /*
             * ============================================================
             * REMPLISSAGE DES CHAMPS DEPUIS LA RÉPONSE AJAX
             * ============================================================
             */

            const fillCompanyFields = (company) => {
                setValue(fields.legalName, company.legalName);
                setValue(fields.commercialName, company.commercialName);
                setValue(fields.siret, company.siret);
                setValue(hiddenFields.siren, company.siren);
                setValue(fields.apeCode, company.apeCode);
                setValue(fields.legalForm, company.legalForm);

                if (!fields.vatNumber?.value) {
                    setValue(fields.vatNumber, company.vatNumber);
                }
            };

            const fillAddressFields = (address) => {
                setValue(hiddenFields.houseNumber, address.houseNumber);
                setValue(hiddenFields.road, address.road);

                if (
                    hiddenFields.addressComplement &&
                    !hiddenFields.addressComplement.value
                ) {
                    setValue(
                        hiddenFields.addressComplement,
                        address.addressComplement
                    );
                }

                setValue(
                    hiddenFields.neighbourhood,
                    address.neighbourhood
                );
                setValue(hiddenFields.suburb, address.suburb);
                setValue(
                    hiddenFields.cityDistrict,
                    address.cityDistrict
                );
                setValue(hiddenFields.hamlet, address.hamlet);
                setValue(hiddenFields.village, address.village);
                setValue(hiddenFields.town, address.town);
                setValue(fields.city, address.city);
                setValue(
                    hiddenFields.municipality,
                    address.municipality
                );
                setValue(hiddenFields.county, address.county);
                setValue(
                    hiddenFields.stateDistrict,
                    address.stateDistrict
                );
                setValue(hiddenFields.state, address.state);
                setValue(hiddenFields.region, address.region);
                setValue(fields.postalCode, address.postalCode);
                setValue(hiddenFields.country, address.country);
                setValue(
                    hiddenFields.countryCode,
                    address.countryCode
                );
                setValue(
                    hiddenFields.displayName,
                    address.osmDisplayName
                );
                setValue(hiddenFields.latitude, address.latitude);
                setValue(hiddenFields.longitude, address.longitude);
                setValue(hiddenFields.osmId, address.osmId);
                setValue(hiddenFields.osmType, address.osmType);
                setValue(
                    hiddenFields.osmCategory,
                    address.osmCategory
                );
                setValue(
                    hiddenFields.osmPlaceType,
                    address.osmPlaceType
                );
                setValue(
                    hiddenFields.nominatimPlaceId,
                    address.nominatimPlaceId
                );

                setValue(
                    fields.addressSearch,
                    address.osmDisplayName
                );

                if (interventionLocation) {
                    interventionLocation.textContent = firstNonEmpty(
                        address.city,
                        address.osmDisplayName
                    );
                }

                if (address.latitude && address.longitude) {
                    updateMap(address.latitude, address.longitude);
                }
            };

            /*
             * ============================================================
             * APPEL AJAX VERS LE CONTRÔLEUR SYMFONY
             * ============================================================
             */

            const fetchCompanyBySiret = async () => {
                const siret = normalizeSiret(fields.siret?.value);

                setValue(fields.siret, siret);

                if (siret.length !== 14) {
                    setStatus(
                        companyStatus,
                        'Le numéro SIRET doit contenir exactement 14 chiffres.',
                        'danger'
                    );

                    fields.siret?.focus();

                    return;
                }

                // Annule une éventuelle requête précédente encore en vol.
                lookupAbortController?.abort();
                lookupAbortController = new AbortController();

                if (verifyCompanyButton) {
                    verifyCompanyButton.disabled = true;
                }

                setStatus(
                    companyStatus,
                    'Recherche de l’entreprise en cours…',
                    'secondary'
                );

                try {
                    const url = SIRET_LOOKUP_URL_TEMPLATE.replace(
                        '00000000000000',
                        siret
                    );

                    const response = await fetch(url, {
                        method: 'GET',
                        headers: {
                            Accept: 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        signal: lookupAbortController.signal
                    });

                    const payload = await response.json();

                    if (!response.ok || payload.success !== true) {
                        throw new Error(
                            payload.message ??
                                `Erreur serveur : HTTP ${response.status}.`
                        );
                    }

                    fillCompanyFields(payload.company ?? {});
                    fillAddressFields(payload.address ?? {});

                    setStatus(
                        companyStatus,
                        'Entreprise trouvée : tous les champs ont été remplis automatiquement.',
                        'success'
                    );

                    setStatus(
                        addressStatus,
                        'Adresse et coordonnées géographiques remplies depuis le SIRET.',
                        'success'
                    );
                } catch (error) {
                    if (error.name === 'AbortError') {
                        return;
                    }

                    console.error(
                        'Erreur lors de la recherche SIRET :',
                        error
                    );

                    setStatus(
                        companyStatus,
                        error instanceof Error
                            ? error.message
                            : 'Une erreur inconnue est survenue.',
                        'danger'
                    );
                } finally {
                    if (verifyCompanyButton) {
                        verifyCompanyButton.disabled = false;
                    }
                }
            };

            verifyCompanyButton?.addEventListener(
                'click',
                fetchCompanyBySiret
            );

            /*
             * Normalisation à la saisie + déclenchement automatique
             * dès que les 14 chiffres sont présents (saisie ou collage).
             */
            let autoLookupTimer = null;

            fields.siret?.addEventListener('input', () => {
                fields.siret.value = normalizeSiret(
                    fields.siret.value
                );

                window.clearTimeout(autoLookupTimer);

                if (fields.siret.value.length === 14) {
                    autoLookupTimer = window.setTimeout(
                        fetchCompanyBySiret,
                        400
                    );
                }
            });

            fields.siret?.addEventListener('keydown', (event) => {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    fetchCompanyBySiret();
                }
            });

            /*
             * ============================================================
             * RECHERCHE D'ADRESSE MANUELLE (Nominatim)
             * ============================================================
             */

            const searchAddressWithNominatim = async (query) => {
                const normalizedQuery = String(query ?? '').trim();

                if (normalizedQuery.length < 5) {
                    throw new Error(
                        'Saisissez une adresse suffisamment précise.'
                    );
                }

                setStatus(
                    addressStatus,
                    'Recherche de l’adresse en cours…'
                );

                const parameters = new URLSearchParams({
                    q: normalizedQuery,
                    format: 'jsonv2',
                    addressdetails: '1',
                    limit: '1',
                    countrycodes: 'fr',
                    'accept-language': 'fr'
                });

                const response = await fetch(
                    `${NOMINATIM_SEARCH_API}?${parameters.toString()}`,
                    {
                        headers: { Accept: 'application/json' }
                    }
                );

                if (!response.ok) {
                    throw new Error(
                        `OpenStreetMap a répondu avec le code ${response.status}.`
                    );
                }

                const results = await response.json();
                const result = Array.isArray(results)
                    ? results[0]
                    : null;

                if (!result) {
                    throw new Error(
                        'Aucune adresse correspondante n’a été trouvée.'
                    );
                }

                const address = result.address || {};

                fillAddressFields({
                    houseNumber: address.house_number,
                    road: address.road,
                    neighbourhood: firstNonEmpty(
                        address.neighbourhood,
                        address.quarter
                    ),
                    suburb: address.suburb,
                    cityDistrict: firstNonEmpty(
                        address.city_district,
                        address.borough
                    ),
                    hamlet: address.hamlet,
                    village: address.village,
                    town: address.town,
                    city: firstNonEmpty(
                        address.city,
                        address.town,
                        address.village,
                        address.municipality,
                        address.hamlet
                    ),
                    municipality: address.municipality,
                    county: address.county,
                    stateDistrict: address.state_district,
                    state: address.state,
                    region: firstNonEmpty(
                        address.region,
                        address.state
                    ),
                    postalCode: address.postcode,
                    country: address.country,
                    countryCode: address.country_code
                        ? String(address.country_code).toUpperCase()
                        : '',
                    osmDisplayName: result.display_name,
                    latitude: result.lat,
                    longitude: result.lon,
                    osmId: result.osm_id,
                    osmType: result.osm_type,
                    osmCategory: firstNonEmpty(
                        result.category,
                        result.class
                    ),
                    osmPlaceType: firstNonEmpty(
                        result.addresstype,
                        result.type
                    ),
                    nominatimPlaceId: result.place_id
                });

                setStatus(
                    addressStatus,
                    'Adresse vérifiée et champs géographiques remplis.',
                    'success'
                );
            };

            searchAddressButton?.addEventListener('click', async () => {
                searchAddressButton.disabled = true;

                try {
                    await searchAddressWithNominatim(
                        fields.addressSearch?.value
                    );
                } catch (error) {
                    console.error(error);
                    setStatus(
                        addressStatus,
                        error instanceof Error
                            ? error.message
                            : 'Une erreur est survenue.',
                        'danger'
                    );
                } finally {
                    searchAddressButton.disabled = false;
                }
            });

            fields.addressSearch?.addEventListener(
                'keydown',
                (event) => {
                    if (event.key === 'Enter') {
                        event.preventDefault();
                        searchAddressButton?.click();
                    }
                }
            );

            /*
             * ============================================================
             * NAVIGATION ENTRE PANNEAUX
             * ============================================================
             */

            document
                .querySelectorAll('.param-nav__lien')
                .forEach((link) => {
                    link.addEventListener('click', () => {
                        document
                            .querySelectorAll('.param-nav__lien')
                            .forEach((element) => {
                                element.classList.toggle(
                                    'actif',
                                    element === link
                                );
                            });

                        document
                            .querySelectorAll('.param-panneau')
                            .forEach((panel) => {
                                panel.classList.toggle(
                                    'actif',
                                    panel.id ===
                                    `panneau-${link.dataset.panneau}`
                                );
                            });

                        if (
                            link.dataset.panneau === 'zone' &&
                            map
                        ) {
                            window.setTimeout(
                                () => map.invalidateSize(),
                                100
                            );
                        }
                    });
                });

            /*
             * ============================================================
             * RAYON D'INTERVENTION
             * ============================================================
             */

            if (radiusInput && radiusValue) {
                const refreshRadius = () => {
                    const radius = Number(radiusInput.value || 25);
                    radiusValue.textContent = `${radius} km`;

                    if (
                        hiddenFields.latitude?.value &&
                        hiddenFields.longitude?.value
                    ) {
                        updateMap(
                            hiddenFields.latitude.value,
                            hiddenFields.longitude.value
                        );
                    }
                };

                radiusInput.addEventListener('input', refreshRadius);
                refreshRadius();
            }

            document
                .querySelectorAll('.zone-chip button')
                .forEach((button) => {
                    button.addEventListener('click', () => {
                        button.closest('.zone-chip')?.remove();
                    });
                });

            initializeMap();

            if (
                hiddenFields.latitude?.value &&
                hiddenFields.longitude?.value
            ) {
                updateMap(
                    hiddenFields.latitude.value,
                    hiddenFields.longitude.value
                );
            }
        });
    </script>
        <script>
        document.addEventListener('DOMContentLoaded', () => {
            const btnChanger = document.getElementById('btn-changer-photo');
            const inputFile = document.getElementById('avatar-input-file');
            const apercuImage = document.getElementById('avatar-apercu-image');
            const apercuInitiales = document.getElementById('avatar-apercu-initiales');

            if (!btnChanger || !inputFile || !apercuImage) {
                return;
            }

            btnChanger.addEventListener('click', (event) => {
                event.preventDefault();
                inputFile.click();
            });

            inputFile.addEventListener('change', () => {
                const fichier = inputFile.files?.[0];

                if (!fichier) {
                    return;
                }

                const urlApercu = URL.createObjectURL(fichier);

                apercuImage.src = urlApercu;
                apercuImage.style.display = '';

                if (apercuInitiales) {
                    apercuInitiales.style.display = 'none';
                }

                apercuImage.onload = () => {
                    URL.revokeObjectURL(urlApercu);
                };
            });
        });
    </script>
{% endblock %}


