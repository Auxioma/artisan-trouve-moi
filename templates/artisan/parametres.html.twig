{% extends 'artisan/base_artisan.html.twig' %}

{% set menu_actif = 'parametres' %}

{% macro carte_prestation(sf, numero) %}
    <div class="service-card{% if sf.isActive.vars.data %} est-actif{% endif %}" data-service-item>

        {# En-tête de la carte #}
        <div class="service-card__entete">
            <span class="service-card__numero" aria-hidden="true">{{ numero }}</span>
            <div class="service-card__titre-wrap">
                <span class="service-card__nom">{{ sf.title.vars.value ?: 'Nouvelle prestation' }}</span>
                <span class="service-card__meta">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 21c4.5-4 7-7.6 7-11a7 7 0 1 0-14 0c0 3.4 2.5 7 7 11z"/><circle cx="12" cy="10" r="2.6"/></svg>
                {% if sf.category.vars.value %}{{ sf.category.vars.value }}{% else %}Catégorie non définie{% endif %}
                    {% if sf.priceFrom.vars.value %} · à partir de {{ sf.priceFrom.vars.value }} €{% endif %}
            </span>
            </div>
            <div class="service-card__controles">
                <div class="form-check form-switch mb-0">
                    {{ form_widget(sf.isActive, { attr: { class: 'form-check-input', role: 'switch', 'aria-label': 'Afficher cette prestation sur le profil' } }) }}
                </div>
                <button class="service-card__supprimer" type="button" data-remove-service aria-label="Supprimer cette prestation" title="Supprimer">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6M10 11v6M14 11v6"/></svg>
                </button>
            </div>
        </div>

        {# Corps — grille 2 colonnes #}
        <div class="service-card__corps">
            <div class="service-card__grille">

                {# Ligne 1 : Catégorie | Nom de la prestation #}
                <div>
                    {{ form_label(sf.category, 'Catégorie de métier', { label_attr: { class: 'form-label' } }) }}
                    {{ form_widget(sf.category, { attr: { class: 'form-select' } }) }}
                    {{ form_errors(sf.category) }}
                </div>
                <div>
                    {{ form_label(sf.title, 'Nom de la prestation', { label_attr: { class: 'form-label' } }) }}
                    {{ form_widget(sf.title, { attr: { class: 'form-control', placeholder: 'Ex : Remplacement de chauffe-eau' } }) }}
                    {{ form_errors(sf.title) }}
                </div>

                {# Ligne 2 : Description — pleine largeur #}
                <div class="service-card__grille--full">
                    {{ form_label(sf.description, 'Description', { label_attr: { class: 'form-label' } }) }}
                    {{ form_widget(sf.description, { attr: { class: 'form-control', rows: 3, maxlength: 2000, placeholder: 'Décrivez les travaux inclus, les matériaux utilisés, les garanties…' } }) }}
                    {{ form_errors(sf.description) }}
                </div>

                {# Ligne 3 : Prix à partir de | Prix unitaire #}
                <div>
                    {{ form_label(sf.priceFrom, 'Prix à partir de', { label_attr: { class: 'form-label' } }) }}
                    <div class="input-unite">
                        {{ form_widget(sf.priceFrom, { attr: { class: 'form-control', placeholder: '0,00', min: 0, step: '0.01', inputmode: 'decimal' } }) }}
                        <span class="input-unite__label">€</span>
                    </div>
                    {{ form_errors(sf.priceFrom) }}
                </div>
                <div>
                    {{ form_label(sf.priceUnit, 'Prix unitaire', { label_attr: { class: 'form-label' } }) }}
                    {{ form_widget(sf.priceUnit, { attr: { class: 'form-select' } }) }}
                    {{ form_errors(sf.priceUnit) }}
                </div>

                {# Ligne 4 : Durée en heures | Ordre d'affichage #}
                <div>
                    {{ form_label(sf.estimatedDurationHours, 'Durée en heures', { label_attr: { class: 'form-label' } }) }}
                    <div class="input-unite">
                        {{ form_widget(sf.estimatedDurationHours, { attr: { class: 'form-control', placeholder: '2', min: 1, inputmode: 'numeric' } }) }}
                        <span class="input-unite__label">h</span>
                    </div>
                    {{ form_errors(sf.estimatedDurationHours) }}
                </div>
                <div>
                    {{ form_label(sf.position, "Ordre d'affichage", { label_attr: { class: 'form-label' } }) }}
                    {{ form_widget(sf.position, { attr: { class: 'form-control', min: 0, inputmode: 'numeric', placeholder: '1' } }) }}
                    {{ form_errors(sf.position) }}
                </div>

            </div>{# /service-card__grille #}

            {{ form_errors(sf) }}
        </div>
    </div>
{% endmacro %}

{% block title %}Paramètres{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="">
{% endblock %}

{% block body %}
    {{ form_start(form) }}

    <div class="dash-header">
        <div>
            <h1>Paramètres</h1>
            <p>Gérez votre profil public, votre zone d'intervention, vos notifications et la sécurité du compte.</p>
        </div>
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show m-3" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                </div>
            {% endfor %}
        {% endfor %}
        <div class="dash-header__actions">
            <button class="btn btn-dash-primary" type="submit">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg>
                Enregistrer les modifications
            </button>
        </div>
    </div>

    <div class="row g-3">

        {# Navigation des paramètres #}
        <div class="col-12 col-lg-3">
            <nav class="param-nav" aria-label="Sections des paramètres">
                <button class="param-nav__lien actif" type="button" data-panneau="profil">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16M8 7h2M8 11h2M8 15h2M13 7h1M13 11h1M16 9h4v12M18 13h.01M18 17h.01"/><path d="M2 21h20"/></svg>
                    Profil de l'entreprise
                </button>
                <button class="param-nav__lien" type="button" data-panneau="description">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16v16H4z"/><path d="M8 8h8M8 12h8M8 16h5"/></svg>
                    Description
                </button>
                <button class="param-nav__lien" type="button" data-panneau="documents">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16v16H4z"/><path d="M8 8h8M8 12h8M8 16h5"/></svg>
                    Document légal
                </button>
                <button class="param-nav__lien" type="button" data-panneau="zone">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21c4.5-4 7-7.6 7-11a7 7 0 1 0-14 0c0 3.4 2.5 7 7 11z"/><circle cx="12" cy="10" r="2.6"/></svg>
                    Zone d'intervention
                </button>
                <button class="param-nav__lien" type="button" data-panneau="prestations">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18v3h3l6.3-6.3a4 4 0 0 0 5.4-5.4l-2.8 2.8-2.4-2.4z"/></svg>
                    Prestations
                </button>
                <button class="param-nav__lien" type="button" data-panneau="notifications">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>
                    Notifications
                </button>
                <button class="param-nav__lien" type="button" data-panneau="securite">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="10" width="18" height="11" rx="2"/><path d="M7 10V7a5 5 0 0 1 10 0v3"/></svg>
                    Sécurité
                </button>
            </nav>
        </div>

        <div class="col-12 col-lg-9">

            {# ===== PANNEAU PROFIL ===== #}
            {% include 'artisan/_partials/_parametres/_profile_de_l_entreprise.html.twig' %}

            {# ===== PANNEAU DESCRIPTION ===== #}
            {% include 'artisan/_partials/_parametres/_description.html.twig' %}

            {# ===== PANNEAU DOCUMENTS LEGAL ===== #}
            {% include 'artisan/_partials/_parametres/_documents.html.twig' %}

            {# ===== PANNEAU ZONE ===== #}
            {% include 'artisan/_partials/_parametres/_zone_intervention.html.twig' %}

            {# ===== PANNEAU PRESTATIONS ===== #}
            {% include 'artisan/_partials/_parametres/_prestations.html.twig' %}
*
            {# ===== PANNEAU NOTIFICATIONS ===== #}
            {% include 'artisan/_partials/_parametres/_notifications.html.twig' %}

            {# ===== PANNEAU SÉCURITÉ ===== #}
            {% include 'artisan/_partials/_parametres/_securite.html.twig' %}

        </div>
    </div>

    {{ form_end(form) }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            'use strict';

            const byId = id => document.getElementById(id);
            const pick = (id, suffix) => byId(id) || document.querySelector(`[name$="${suffix}"]`);
            const target = name => document.querySelector(`[data-osm-address-target="${name}"]`);

            const latitudeInput = target('latitude');
            const longitudeInput = target('longitude');
            const cityInput = pick('ville', '[artisanProfile][city]');
            const addressInput = pick('adresse-professionnelle', '[artisanProfile][addressSearch]');
            const interventionLocation = byId('intervention-location');
            const radiusInput = pick('rayon', '[artisanProfile][travelRadiusKm]');
            const radiusValue = byId('rayon-valeur');

            const refreshInsuranceDetails = toggle => {
                const details = document.querySelector(`[data-insurance-details="${toggle.dataset.insuranceToggle}"]`);

                if (details) {
                    details.hidden = !toggle.checked;
                }
            };

            document.querySelectorAll('[data-insurance-toggle]').forEach(toggle => {
                refreshInsuranceDetails(toggle);
                toggle.addEventListener('change', () => refreshInsuranceDetails(toggle));
            });

            let map = null;
            let marker = null;
            let circle = null;

            const initMap = () => {
                if (map || !window.L || !byId('intervention-map')) {
                    return;
                }

                map = L.map('intervention-map').setView([46.603354, 1.888334], 5);

                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    maxZoom: 19,
                    attribution: '© OpenStreetMap'
                }).addTo(map);
            };

            const updateMap = (latitude, longitude) => {
                initMap();

                if (!map) {
                    return;
                }

                const lat = Number(latitude);
                const lng = Number(longitude);

                if (!Number.isFinite(lat) || !Number.isFinite(lng)) {
                    return;
                }

                const radiusKm = Math.max(1, Number(radiusInput?.value || 25));

                if (marker) {
                    marker.setLatLng([lat, lng]);
                } else {
                    marker = L.marker([lat, lng]).addTo(map);
                }

                if (circle) {
                    circle.setLatLng([lat, lng]);
                    circle.setRadius(radiusKm * 1000);
                } else {
                    circle = L.circle([lat, lng], {
                        radius: radiusKm * 1000
                    }).addTo(map);
                }

                map.fitBounds(circle.getBounds(), {
                    padding: [24, 24]
                });
            };

            const refreshInterventionLabel = () => {
                if (!interventionLocation) {
                    return;
                }

                const city = String(cityInput?.value || '').trim();
                const address = String(addressInput?.value || '').trim();

                interventionLocation.textContent = city || address || 'votre adresse professionnelle';
            };

            const validateCurrentPanel = () => {
                const currentPanel = document.querySelector('.param-panneau.actif');

                if (!currentPanel) {
                    return true;
                }

                const fields = currentPanel.querySelectorAll(
                    'input:not([type="hidden"]):not([type="button"]):not([type="submit"]):not([type="reset"]):not([type="checkbox"]):not([type="radio"]):not([type="file"]), select, textarea'
                );

                let firstInvalidField = null;

                fields.forEach(field => {
                    const style = window.getComputedStyle(field);
                    const isVisible =
                        field.getClientRects().length > 0 &&
                        style.display !== 'none' &&
                        style.visibility !== 'hidden';

                    const isIgnored =
                        field.disabled ||
                        field.readOnly ||
                        field.hasAttribute('data-navigation-optional') ||
                        !isVisible;

                    if (isIgnored) {
                        field.classList.remove('is-invalid');
                        field.removeAttribute('aria-invalid');
                        return;
                    }

                    const isEmpty = String(field.value ?? '').trim() === '';

                    if (isEmpty) {
                        field.classList.add('is-invalid');
                        field.setAttribute('aria-invalid', 'true');

                        if (!firstInvalidField) {
                            firstInvalidField = field;
                        }
                    } else {
                        field.classList.remove('is-invalid');
                        field.removeAttribute('aria-invalid');
                    }
                });

                if (!firstInvalidField) {
                    return true;
                }

                firstInvalidField.scrollIntoView({
                    behavior: 'smooth',
                    block: 'center'
                });

                window.setTimeout(() => firstInvalidField.focus(), 300);

                return false;
            };

            const removeFieldError = event => {
                const field = event.target;

                if (
                    !(field instanceof HTMLInputElement) &&
                    !(field instanceof HTMLSelectElement) &&
                    !(field instanceof HTMLTextAreaElement)
                ) {
                    return;
                }

                if (
                    field.classList.contains('is-invalid') &&
                    String(field.value ?? '').trim() !== ''
                ) {
                    field.classList.remove('is-invalid');
                    field.removeAttribute('aria-invalid');
                }
            };

            document.addEventListener('input', removeFieldError);
            document.addEventListener('change', removeFieldError);

            document.querySelectorAll('.param-nav__lien').forEach(link => {
                link.addEventListener('click', event => {
                    event.preventDefault();

                    const currentLink = document.querySelector('.param-nav__lien.actif');

                    if (currentLink === link) {
                        return;
                    }

                    if (!validateCurrentPanel()) {
                        return;
                    }

                    document.querySelectorAll('.param-nav__lien').forEach(navLink => {
                        navLink.classList.toggle('actif', navLink === link);
                    });

                    document.querySelectorAll('.param-panneau').forEach(panel => {
                        panel.classList.toggle(
                            'actif',
                            panel.id === `panneau-${link.dataset.panneau}`
                        );
                    });

                    if (link.dataset.panneau === 'zone') {
                        initMap();

                        window.setTimeout(() => {
                            map?.invalidateSize();

                            if (latitudeInput?.value && longitudeInput?.value) {
                                updateMap(latitudeInput.value, longitudeInput.value);
                            }
                        }, 150);
                    }
                });
            });

            if (radiusInput && radiusValue) {
                const refreshRadius = () => {
                    radiusValue.textContent = `${radiusInput.value || 25} km`;

                    if (latitudeInput?.value && longitudeInput?.value) {
                        updateMap(latitudeInput.value, longitudeInput.value);
                    }
                };

                radiusInput.addEventListener('input', refreshRadius);
                refreshRadius();
            }

            cityInput?.addEventListener('input', refreshInterventionLabel);
            addressInput?.addEventListener('input', refreshInterventionLabel);

            document.querySelectorAll('.zone-chip button').forEach(button => {
                button.addEventListener('click', () => {
                    button.closest('.zone-chip')?.remove();
                });
            });

            refreshInterventionLabel();
            initMap();

            if (latitudeInput?.value && longitudeInput?.value) {
                updateMap(latitudeInput.value, longitudeInput.value);
            }
        });
    </script>

    <script>
        /* Avatar preview */
        document.addEventListener('DOMContentLoaded',()=>{
            const btnC=document.getElementById('btn-changer-photo');
            const inp =document.getElementById('avatar-input-file');
            const img =document.getElementById('avatar-apercu-image');
            const init=document.getElementById('avatar-apercu-initiales');
            if(!btnC||!inp||!img)return;
            btnC.addEventListener('click',e=>{e.preventDefault();inp.click();});
            inp.addEventListener('change',()=>{
                const f=inp.files?.[0]; if(!f)return;
                const url=URL.createObjectURL(f);
                img.src=url; img.style.display='';
                if(init)init.style.display='none';
                img.onload=()=>URL.revokeObjectURL(url);
            });
        });
    </script>

    <script>
        /* Collection dynamique des prestations */
        document.addEventListener('DOMContentLoaded', function () {
            const collection = document.querySelector('[data-services-collection]');
            if (!collection) return;
            const list      = collection.querySelector('[data-services-list]');
            const prototype = collection.dataset.prototype;
            if (!list || !prototype) return;

            const updateNums = () => {
                list.querySelectorAll('[data-service-item]').forEach((item, i) => {
                    const badge = item.querySelector('.service-card__numero');
                    if (badge) badge.textContent = i + 1;
                });
            };

            const removeEmpty = () => list.querySelector('[data-services-empty]')?.remove();

            const createEmpty = () => {
                if (list.querySelector('[data-service-item]') || list.querySelector('[data-services-empty]')) return;
                list.insertAdjacentHTML('beforeend', `
            <div class="services-vide" data-services-empty>
                <span class="services-vide__icone">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18v3h3l6.3-6.3a4 4 0 0 0 5.4-5.4l-2.8 2.8-2.4-2.4z"/>
                    </svg>
                </span>
                <b>Aucune prestation enregistrée</b>
                <p>Ajoutez vos services pour qu'ils apparaissent sur votre fiche publique avec leurs tarifs indicatifs.</p>
                <button class="btn btn-dash-ghost btn-sm" type="button" data-add-service>
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                    Ajouter ma première prestation
                </button>
            </div>`);
            };

            const updateCounter = () => {
                const cpt = collection.querySelector('.services-compteur');
                if (!cpt) return;
                const n = list.querySelectorAll('[data-service-item]').length;
                cpt.innerHTML = `<b>${n}</b> prestation${n > 1 ? 's' : ''} enregistrée${n > 1 ? 's' : ''}`;
            };

            const wire = (card) => {
                /* Bouton supprimer */
                card.querySelector('[data-remove-service]')?.addEventListener('click', () => {
                    card.remove(); updateNums(); createEmpty(); updateCounter();
                });
                /* Mise à jour du nom dans l'en-tête */
                const titleInput = card.querySelector('input[name*="[title]"]');
                const nomDisplay = card.querySelector('.service-card__nom');
                if (titleInput && nomDisplay) {
                    titleInput.addEventListener('input', () => {
                        nomDisplay.textContent = titleInput.value || 'Nouvelle prestation';
                    });
                }
                /* Classe est-actif selon le toggle */
                const toggle = card.querySelector('input[type="checkbox"][name*="[isActive]"]');
                if (toggle) {
                    const refresh = () => card.classList.toggle('est-actif', toggle.checked);
                    toggle.addEventListener('change', refresh);
                    refresh();
                }
            };

            const addService = () => {
                removeEmpty();
                const idx  = parseInt(collection.dataset.index || '0', 10);

                /* Le prototype contient DEJA la carte complete (macro Twig) :
                   __name__ -> index des champs, __num__ -> numero affiche */
                const html = prototype
                    .replace(/__name__/g, idx)
                    .replace(/__num__/g, idx + 1);

                collection.dataset.index = String(idx + 1);

                const wrap = document.createElement('div');
                wrap.innerHTML = html.trim();
                const card = wrap.firstElementChild;
                if (!card) return;

                list.appendChild(card);
                wire(card);
                updateNums();
                updateCounter();
                card.scrollIntoView({ behavior: 'smooth', block: 'center' });
                card.querySelector('input[name*="[title]"]')?.focus();
            };

            collection.addEventListener('click', e => {
                if (e.target.closest('[data-add-service]')) addService();
            });

            list.querySelectorAll('[data-service-item]').forEach(wire);
            updateNums();
        });
    </script>
{% endblock %}
