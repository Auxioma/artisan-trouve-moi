{% extends 'artisan/base_artisan.html.twig' %}

{% set menu_actif = 'parametres' %}

{% block title %}Paramètres{% endblock %}


{% block stylesheets %}
    {{ parent() }}
    <link
        rel="stylesheet"
        href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        crossorigin=""
    >
{% endblock %}

{% block body %}
    {{ form_start(form) }}

    <div class="dash-header">
        <div>
            <h1>Paramètres</h1>
            <p>
                Gérez votre profil public, votre zone d'intervention,
                vos notifications et la sécurité du compte.
            </p>
        </div>

        <div class="dash-header__actions">
            <button class="btn btn-dash-primary" type="submit">
                <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <circle cx="12" cy="12" r="9"/>
                    <path d="m8.5 12.5 2.5 2.5 5-5.5"/>
                </svg>

                Enregistrer les modifications
            </button>
        </div>
    </div>

    <div class="row g-3">

        <!-- Navigation des paramètres -->
        <div class="col-12 col-lg-3">
            <nav
                class="param-nav"
                aria-label="Sections des paramètres"
            >
                <button
                    class="param-nav__lien actif"
                    type="button"
                    data-panneau="profil"
                >
                    <svg
                        width="15"
                        height="15"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <path d="M4 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16M8 7h2M8 11h2M8 15h2M13 7h1M13 11h1M16 9h4v12M18 13h.01M18 17h.01"/>
                        <path d="M2 21h20"/>
                    </svg>

                    Profil de l'entreprise
                </button>

                <button
                    class="param-nav__lien"
                    type="button"
                    data-panneau="description"
                >
                    <svg
                        width="15"
                        height="15"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <path d="M4 4h16v16H4z"/>
                        <path d="M8 8h8M8 12h8M8 16h5"/>
                    </svg>

                    Description
                </button>

                <button
                    class="param-nav__lien"
                    type="button"
                    data-panneau="zone"
                >
                    <svg
                        width="15"
                        height="15"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <path d="M12 21c4.5-4 7-7.6 7-11a7 7 0 1 0-14 0c0 3.4 2.5 7 7 11z"/>
                        <circle cx="12" cy="10" r="2.6"/>
                    </svg>

                    Zone d'intervention
                </button>

                <button
                    class="param-nav__lien"
                    type="button"
                    data-panneau="notifications"
                >
                    <svg
                        width="15"
                        height="15"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/>
                        <path d="M13.7 21a2 2 0 0 1-3.4 0"/>
                    </svg>

                    Notifications
                </button>

                <button
                    class="param-nav__lien"
                    type="button"
                    data-panneau="securite"
                >
                    <svg
                        width="15"
                        height="15"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <rect x="3" y="10" width="18" height="11" rx="2"/>
                        <path d="M7 10V7a5 5 0 0 1 10 0v3"/>
                    </svg>

                    Sécurité
                </button>
            </nav>
        </div>

        <div class="col-12 col-lg-9">

            <!-- ===== PANNEAU PROFIL ===== -->
            <div class="param-panneau actif" id="panneau-profil">
                <div class="dash-card">

                    <p class="param-section-titre">
                        Identité de l'entreprise
                    </p>

                    <div class="param-logo mb-3">
                        <span class="avatar avatar--lg avatar--safran" id="avatar-apercu-initiales"
                                {% if app.user.avatarFilename %}style="display:none;"{% endif %}>
                            {{ (app.user.firstName|first ~ app.user.lastName|first)|upper }}
                        </span>

                        <img id="avatar-apercu-image"
                             class="avatar avatar--lg"
                             alt="Photo de profil"
                            {% if app.user.avatarFilename %}
                            src="{{ vich_uploader_asset(app.user, 'avatarFile') }}"
                        {% else %}
                            src="" style="display:none;"
                            {% endif %}>

                        <div>
                            <div class="d-flex gap-2 flex-wrap">
                                <button class="btn btn-dash-ghost btn-sm" type="button" id="btn-changer-photo">Changer la photo</button>
                                <button class="btn btn-dash-ghost btn-sm" type="button" id="btn-supprimer-photo">Supprimer</button>
                            </div>
                            <p>PNG ou JPG, 2 Mo max. Seules vos initiales sont visibles par défaut.</p>

                            {# input file réel, masqué #}
                            <div class="d-none">
                                {{ form_widget(form.avatarFile.file, {
                                    id: 'avatar-input-file',
                                    attr: {
                                        accept: 'image/png,image/jpeg'
                                    }
                                }) }}
                                {% if form.avatarFile.delete is defined %}
                                    {{ form_widget(form.avatarFile.delete, { attr: { id: 'avatar-input-delete' } }) }}
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <div class="row g-3">

                        <div class="col-12 col-md-6">
                            <label
                                class="form-label"
                                for="nom-entreprise"
                            >
                                Nom de l'entreprise
                            </label>

                            {{ form_widget(form.artisanProfile.legalName, {
                                attr: {
                                    class: 'form-control',
                                    id: 'nom-entreprise',
                                    autocomplete: 'organization',
                                    placeholder: 'Plomberie Express'
                                }
                            }) }}
                        </div>

                        <div class="col-12 col-md-6">
                            <label
                                class="form-label"
                                for="nom-commercial"
                            >
                                Nom Commercial
                            </label>

                            {{ form_widget(form.artisanProfile.commercialName, {
                                attr: {
                                    class: 'form-control',
                                    id: 'nom-commercial',
                                    autocomplete: 'organization',
                                    placeholder: 'Plomberie Express'
                                }
                            }) }}
                        </div>

                        <div class="col-12 col-md-6">
                            <label
                                class="form-label"
                                for="prenom"
                            >
                                Prénom
                            </label>

                            {{ form_widget(form.firstName, {
                                attr: {
                                    class: 'form-control',
                                    id: 'prenom',
                                    autocomplete: 'given-name',
                                    placeholder: 'Prénom'
                                }
                            }) }}
                        </div>

                        <div class="col-12 col-md-6">
                            <label
                                class="form-label"
                                for="nom"
                            >
                                Nom
                            </label>

                            {{ form_widget(form.lastName, {
                                attr: {
                                    class: 'form-control',
                                    id: 'nom',
                                    autocomplete: 'family-name',
                                    placeholder: 'Nom'
                                }
                            }) }}
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label" for="siret">
                                SIRET
                            </label>

                            <div class="d-flex gap-2 align-items-center">
                                {{ form_widget(form.artisanProfile.siret, {
                                    id: 'siret',
                                    attr: {
                                        class: 'form-control',
                                        autocomplete: 'off',
                                        placeholder: '12345678901234'
                                    }
                                }) }}

                                <button
                                    class="btn btn-dash-ghost flex-shrink-0"
                                    type="button"
                                    id="verify-company"
                                >
                                    Vérifier
                                </button>
                            </div>

                            <div
                                id="company-api-status"
                                class="form-text mt-2"
                                role="status"
                                aria-live="polite"
                            ></div>
                        </div>

                        <div class="col-12 col-md-6">
                            <label
                                class="form-label"
                                for="ape-code"
                            >
                                APE
                            </label>

                            {{ form_widget(form.artisanProfile.apeCode, {
                                attr: {
                                    class: 'form-control',
                                    id: 'ape-code',
                                    autocomplete: 'off',
                                    placeholder: '43.22A'
                                }
                            }) }}
                        </div>

                        <div class="col-12 col-md-6">
                            <label
                                class="form-label"
                                for="forme-juridique"
                            >
                                Statut juridique
                            </label>

                            {{ form_widget(form.artisanProfile.legalForm, {
                                attr: {
                                    class: 'form-control',
                                    id: 'forme-juridique',
                                    autocomplete: 'off',
                                    placeholder: 'SARL, SAS, EI...'
                                }
                            }) }}
                        </div>

                        <div class="col-12 col-md-6">
                            <label
                                class="form-label"
                                for="numero-tva"
                            >
                                Numéro de TVA
                            </label>

                            {{ form_widget(form.artisanProfile.vatNumber, {
                                attr: {
                                    class: 'form-control',
                                    id: 'numero-tva',
                                    autocomplete: 'off',
                                    placeholder: 'FR00123456789'
                                }
                            }) }}
                        </div>

                        <div class="col-12">
                            <label
                                class="form-label"
                                for="adresse-professionnelle"
                            >
                                Adresse
                            </label>

                            <div class="d-flex gap-2 align-items-center">
                                {{ form_widget(form.artisanProfile.addressSearch, {
                                    attr: {
                                        class: 'form-control',
                                        id: 'adresse-professionnelle',
                                        autocomplete: 'off',
                                        placeholder: 'Saisissez votre adresse complète'
                                    }
                                }) }}

                                <button
                                    class="btn btn-dash-ghost flex-shrink-0"
                                    type="button"
                                    id="search-address"
                                >
                                    Rechercher
                                </button>
                            </div>

                            <div
                                id="address-api-status"
                                class="form-text mt-2"
                                role="status"
                                aria-live="polite"
                            ></div>
                        </div>

                        <div class="col-12 col-md-6">
                            <label
                                class="form-label"
                                for="ville"
                            >
                                Ville
                            </label>

                            {{ form_widget(form.artisanProfile.city, {
                                attr: {
                                    class: 'form-control',
                                    id: 'ville'
                                }
                            }) }}
                        </div>

                        <div class="col-12 col-md-6">
                            <label
                                class="form-label"
                                for="code-postal"
                            >
                                Code postal
                            </label>

                            {{ form_widget(form.artisanProfile.postalCode, {
                                attr: {
                                    id: 'code-postal',
                                    class: 'form-control',
                                }
                            }) }}
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===== PANNEAU DESCRIPTION DE L’ENTREPRISE ===== -->
            <div class="param-panneau" id="panneau-description">
                <div class="dash-card">

                    <p class="param-section-titre">
                        Description de l’entreprise
                    </p>

                    <div class="row g-3">

                        <!-- Adresse e-mail -->
                        <div class="col-12 col-md-6">
                            {{ form_label(
                                form.email,
                                'Adresse e-mail professionnelle',
                                {
                                    label_attr: {
                                    class: 'form-label'
                                }
                                }
                            ) }}

                            {{ form_widget(form.email, {
                                attr: {
                                    class: 'form-control',
                                    autocomplete: 'email',
                                    placeholder: 'contact@entreprise.fr'
                                }
                            }) }}

                            {{ form_errors(form.email) }}
                        </div>

                        <!-- Numéro de téléphone -->
                        <div class="col-12 col-md-6">
                            {{ form_label(
                                form.phoneNumber,
                                'Numéro de téléphone professionnel',
                                {
                                    label_attr: {
                                    class: 'form-label'
                                }
                                }
                            ) }}

                            {{ form_widget(form.phoneNumber, {
                                attr: {
                                    class: 'form-control',
                                    autocomplete: 'tel',
                                    placeholder: '06 12 34 56 78'
                                }
                            }) }}

                            {{ form_errors(form.phoneNumber) }}
                        </div>

                        <!-- Description -->
                        <div class="col-12">
                            {{ form_label(
                                form.artisanProfile.description,
                                'Présentation de votre entreprise',
                                {
                                    label_attr: {
                                    class: 'form-label'
                                }
                                }
                            ) }}

                            {{ form_widget(form.artisanProfile.description, {
                                attr: {
                                    class: 'form-control',
                                    rows: 7,
                                    maxlength: 10000,
                                    placeholder: 'Présentez votre entreprise, votre expérience, vos compétences et les prestations que vous proposez.'
                                }
                            }) }}

                            <div class="form-text">
                                Décrivez clairement votre activité afin d’aider les clients
                                à mieux comprendre vos services.
                            </div>

                            {{ form_errors(form.artisanProfile.description) }}
                        </div>

                    </div>

                    <!-- ===== RESPONSABILITÉ CIVILE PROFESSIONNELLE ===== -->
                    <p class="param-section-titre">
                        Assurance responsabilité civile professionnelle
                    </p>

                    <div class="row g-3">

                        <div class="col-12">
                            <div class="form-check">
                                {{ form_widget(
                                    form.artisanProfile.hasProfessionalLiabilityInsurance,
                                    {
                                        attr: {
                                        class: 'form-check-input'
                                    }
                                    }
                                ) }}

                                {{ form_label(
                                    form.artisanProfile.hasProfessionalLiabilityInsurance,
                                    'Je possède une assurance responsabilité civile professionnelle',
                                    {
                                        label_attr: {
                                        class: 'form-check-label'
                                    }
                                    }
                                ) }}
                            </div>

                            {{ form_errors(
                                form.artisanProfile.hasProfessionalLiabilityInsurance
                            ) }}
                        </div>

                        <!-- Nom de l’assureur -->
                        <div class="col-12 col-md-6">
                            {{ form_label(
                                form.artisanProfile.professionalLiabilityInsurer,
                                'Nom de l’assureur',
                                {
                                    label_attr: {
                                    class: 'form-label'
                                }
                                }
                            ) }}

                            {{ form_widget(
                                form.artisanProfile.professionalLiabilityInsurer,
                                {
                                    attr: {
                                    class: 'form-control',
                                    placeholder: 'Nom de la compagnie d’assurance'
                                }
                                }
                            ) }}

                            {{ form_errors(
                                form.artisanProfile.professionalLiabilityInsurer
                            ) }}
                        </div>

                        <!-- Numéro du contrat -->
                        <div class="col-12 col-md-6">
                            {{ form_label(
                                form.artisanProfile.professionalLiabilityPolicyNumber,
                                'Numéro du contrat',
                                {
                                    label_attr: {
                                    class: 'form-label'
                                }
                                }
                            ) }}

                            {{ form_widget(
                                form.artisanProfile.professionalLiabilityPolicyNumber,
                                {
                                    attr: {
                                    class: 'form-control',
                                    placeholder: 'Numéro de police d’assurance'
                                }
                                }
                            ) }}

                            {{ form_errors(
                                form.artisanProfile.professionalLiabilityPolicyNumber
                            ) }}
                        </div>

                        <!-- Date de début -->
                        <div class="col-12 col-md-6">
                            {{ form_label(
                                form.artisanProfile.professionalLiabilityStartsAt,
                                'Date de début du contrat',
                                {
                                    label_attr: {
                                    class: 'form-label'
                                }
                                }
                            ) }}

                            {{ form_widget(
                                form.artisanProfile.professionalLiabilityStartsAt,
                                {
                                    attr: {
                                    class: 'form-control'
                                }
                                }
                            ) }}

                            {{ form_errors(
                                form.artisanProfile.professionalLiabilityStartsAt
                            ) }}
                        </div>

                        <!-- Date d’expiration -->
                        <div class="col-12 col-md-6">
                            {{ form_label(
                                form.artisanProfile.professionalLiabilityExpiresAt,
                                'Date d’expiration du contrat',
                                {
                                    label_attr: {
                                    class: 'form-label'
                                }
                                }
                            ) }}

                            {{ form_widget(
                                form.artisanProfile.professionalLiabilityExpiresAt,
                                {
                                    attr: {
                                    class: 'form-control'
                                }
                                }
                            ) }}

                            {{ form_errors(
                                form.artisanProfile.professionalLiabilityExpiresAt
                            ) }}
                        </div>

                    </div>

                    <!-- ===== ASSURANCE DÉCENNALE ===== -->
                    <p class="param-section-titre">
                        Assurance décennale
                    </p>

                    <div class="row g-3">

                        <div class="col-12">
                            <div class="form-check">
                                {{ form_widget(
                                    form.artisanProfile.hasDecennialInsurance,
                                    {
                                        attr: {
                                        class: 'form-check-input'
                                    }
                                    }
                                ) }}

                                {{ form_label(
                                    form.artisanProfile.hasDecennialInsurance,
                                    'Je possède une assurance décennale',
                                    {
                                        label_attr: {
                                        class: 'form-check-label'
                                    }
                                    }
                                ) }}
                            </div>

                            {{ form_errors(
                                form.artisanProfile.hasDecennialInsurance
                            ) }}
                        </div>

                        <!-- Nom de l’assureur décennal -->
                        <div class="col-12 col-md-6">
                            {{ form_label(
                                form.artisanProfile.decennialInsurer,
                                'Nom de l’assureur décennal',
                                {
                                    label_attr: {
                                    class: 'form-label'
                                }
                                }
                            ) }}

                            {{ form_widget(
                                form.artisanProfile.decennialInsurer,
                                {
                                    attr: {
                                    class: 'form-control',
                                    placeholder: 'Nom de la compagnie d’assurance'
                                }
                                }
                            ) }}

                            {{ form_errors(
                                form.artisanProfile.decennialInsurer
                            ) }}
                        </div>

                        <!-- Numéro du contrat décennal -->
                        <div class="col-12 col-md-6">
                            {{ form_label(
                                form.artisanProfile.decennialPolicyNumber,
                                'Numéro du contrat décennal',
                                {
                                    label_attr: {
                                    class: 'form-label'
                                }
                                }
                            ) }}

                            {{ form_widget(
                                form.artisanProfile.decennialPolicyNumber,
                                {
                                    attr: {
                                    class: 'form-control',
                                    placeholder: 'Numéro de police d’assurance'
                                }
                                }
                            ) }}

                            {{ form_errors(
                                form.artisanProfile.decennialPolicyNumber
                            ) }}
                        </div>

                        <!-- Date de début de la garantie -->
                        <div class="col-12 col-md-6">
                            {{ form_label(
                                form.artisanProfile.decennialInsuranceStartsAt,
                                'Date de début de la garantie décennale',
                                {
                                    label_attr: {
                                    class: 'form-label'
                                }
                                }
                            ) }}

                            {{ form_widget(
                                form.artisanProfile.decennialInsuranceStartsAt,
                                {
                                    attr: {
                                    class: 'form-control'
                                }
                                }
                            ) }}

                            {{ form_errors(
                                form.artisanProfile.decennialInsuranceStartsAt
                            ) }}
                        </div>

                        <!-- Date d’expiration de la garantie -->
                        <div class="col-12 col-md-6">
                            {{ form_label(
                                form.artisanProfile.decennialInsuranceExpiresAt,
                                'Date d’expiration de la garantie décennale',
                                {
                                    label_attr: {
                                    class: 'form-label'
                                }
                                }
                            ) }}

                            {{ form_widget(
                                form.artisanProfile.decennialInsuranceExpiresAt,
                                {
                                    attr: {
                                    class: 'form-control'
                                }
                                }
                            ) }}

                            {{ form_errors(
                                form.artisanProfile.decennialInsuranceExpiresAt
                            ) }}
                        </div>

                        <!-- Couverture géographique -->
                        <div class="col-12">
                            {{ form_label(
                                form.artisanProfile.decennialGeographicalCoverage,
                                'Zone géographique couverte par la garantie',
                                {
                                    label_attr: {
                                    class: 'form-label'
                                }
                                }
                            ) }}

                            {{ form_widget(
                                form.artisanProfile.decennialGeographicalCoverage,
                                {
                                    attr: {
                                    class: 'form-control',
                                    placeholder: 'Exemple : France métropolitaine'
                                }
                                }
                            ) }}

                            {{ form_errors(
                                form.artisanProfile.decennialGeographicalCoverage
                            ) }}
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===== PANNEAU ZONE ===== -->
            <div class="param-panneau" id="panneau-zone">
                <div class="dash-card">

                    <p class="param-section-titre">
                        Rayon d'intervention
                    </p>

                    <label class="form-label" for="rayon">
                        Autour de
                        <b id="intervention-location">
                            votre adresse professionnelle
                        </b>
                        —
                        <span
                            class="rayon-valeur"
                            id="rayon-valeur"
                        >
                            25 km
                        </span>
                    </label>

                        {{ form_widget(form.artisanProfile.travelRadiusKm, {
                            attr: {
                                oninput: "document.getElementById('travel-radius-value').textContent = this.value + ' km'"
                            }
                        }) }}

                    <p class="small text-secondary mb-3">
                        Vous recevez uniquement les demandes situées
                        dans ce périmètre.
                    </p>

                    <div
                        id="intervention-map"
                        style="height: 390px; border-radius: 14px; overflow: hidden;"
                        aria-label="Carte de la zone d'intervention"
                    ></div>

                    <p class="small text-secondary mt-2 mb-0">
                        Carte et données géographiques © contributeurs
                        OpenStreetMap.
                    </p>


                    <p class="param-section-titre">
                        Catégories de prestations
                    </p>

                    <div class="zone-chips">
                        <span class="zone-chip">
                            Plomberie générale

                            <button
                                type="button"
                                aria-label="Retirer"
                            >
                                ×
                            </button>
                        </span>

                        <span class="zone-chip">
                            Salle de bain

                            <button
                                type="button"
                                aria-label="Retirer"
                            >
                                ×
                            </button>
                        </span>

                        <span class="zone-chip">
                            Chauffage / chauffe-eau

                            <button
                                type="button"
                                aria-label="Retirer"
                            >
                                ×
                            </button>
                        </span>

                        <span class="zone-chip">
                            Débouchage

                            <button
                                type="button"
                                aria-label="Retirer"
                            >
                                ×
                            </button>
                        </span>
                    </div>

                </div>
            </div>

            <!-- ===== PANNEAU NOTIFICATIONS ===== -->
<div
    class="param-panneau"
    id="panneau-notifications"
>
    <div class="dash-card">

        <p class="param-section-titre">
            Activité commerciale
        </p>

