{% extends 'artisan/base_artisan.html.twig' %}

{% set menu_actif = 'calendrier' %}

{% block title %}Calendrier{% endblock %}

{% block body %}

    <div class="dash-header">
      <div>
        <h1>Calendrier</h1>
        <p>3 événements aujourd'hui — prochain rendez-vous à 14 h 00 (Sophie Martin).</p>
      </div>
      <div class="dash-header__actions">
        <button class="btn btn-dash-ghost" type="button"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12M8 7l4-4 4 4"/><path d="M4 17v3a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-3"/></svg>Exporter (.ics)</button>
        <button class="btn btn-dash-primary" type="button"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>Nouvel événement</button>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-12 col-xxl-9">
        <div class="dash-card">
          <div class="cal-entete">
            <button class="mini-cal__fleche" type="button" aria-label="Mois précédent"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 6-6 6 6 6"/></svg></button>
            <span class="cal-entete__mois">Mai 2024</span>
            <button class="mini-cal__fleche" type="button" aria-label="Mois suivant"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 6 6 6-6 6"/></svg></button>
            <button class="btn btn-dash-ghost btn-sm" type="button">Aujourd'hui</button>
            <div class="cal-entete__legende">
              <span><i class="l-rdv"></i>Rendez-vous</span>
              <span><i class="l-chantier"></i>Chantier</span>
              <span><i class="l-relance"></i>Relance devis</span>
            </div>
          </div>
          <div class="cal-scroll">
            <div class="cal-grille">
<div class="cal-grille__entete">Lun</div><div class="cal-grille__entete">Mar</div><div class="cal-grille__entete">Mer</div><div class="cal-grille__entete">Jeu</div><div class="cal-grille__entete">Ven</div><div class="cal-grille__entete">Sam</div><div class="cal-grille__entete dim">Dim</div><div class="cal-jour hors"><span class="cal-jour__num">29</span></div><div class="cal-jour hors"><span class="cal-jour__num">30</span></div><div class="cal-jour"><span class="cal-jour__num">1</span></div><div class="cal-jour"><span class="cal-jour__num">2</span><span class="cal-evt cal-evt--rdv" title="09:00 Visite technique">09:00 Visite technique</span></div><div class="cal-jour"><span class="cal-jour__num">3</span></div><div class="cal-jour"><span class="cal-jour__num">4</span></div><div class="cal-jour dim"><span class="cal-jour__num">5</span></div><div class="cal-jour"><span class="cal-jour__num">6</span><span class="cal-evt cal-evt--chantier" title="Début — Colonne Lyon 8e">Début — Colonne Lyon 8e</span></div><div class="cal-jour"><span class="cal-jour__num">7</span></div><div class="cal-jour"><span class="cal-jour__num">8</span><span class="cal-evt cal-evt--rdv" title="11:00 RDV devis N. Karim">11:00 RDV devis N. Karim</span></div><div class="cal-jour"><span class="cal-jour__num">9</span></div><div class="cal-jour"><span class="cal-jour__num">10</span></div><div class="cal-jour"><span class="cal-jour__num">11</span></div><div class="cal-jour dim"><span class="cal-jour__num">12</span></div><div class="cal-jour"><span class="cal-jour__num">13</span><span class="cal-evt cal-evt--chantier" title="Début — Salle d'eau Bron">Début — Salle d'eau Bron</span></div><div class="cal-jour"><span class="cal-jour__num">14</span><span class="cal-evt cal-evt--chantier" title="Entretien chaudière TL">Entretien chaudière TL</span><span class="cal-evt cal-evt--rdv" title="16:00 Appel syndic">16:00 Appel syndic</span></div><div class="cal-jour"><span class="cal-jour__num">15</span><span class="cal-evt cal-evt--chantier" title="Robinetterie J. Moreau">Robinetterie J. Moreau</span></div><div class="cal-jour aujourdhui"><span class="cal-jour__num">16</span><span class="cal-evt cal-evt--rdv" title="14:00 RDV chantier S. Martin">14:00 RDV chantier S. Martin</span><span class="cal-evt cal-evt--chantier" title="Suivi — Salle d'eau Bron">Suivi — Salle d'eau Bron</span></div><div class="cal-jour"><span class="cal-jour__num">17</span><span class="cal-evt cal-evt--rdv" title="14:00 Détails techniques SM">14:00 Détails techniques SM</span></div><div class="cal-jour"><span class="cal-jour__num">18</span><span class="cal-evt cal-evt--relance" title="Relance devis N. Karim">Relance devis N. Karim</span></div><div class="cal-jour dim"><span class="cal-jour__num">19</span><span class="cal-evt cal-evt--relance" title="Relance devis C. Petit">Relance devis C. Petit</span></div><div class="cal-jour"><span class="cal-jour__num">20</span></div><div class="cal-jour"><span class="cal-jour__num">21</span></div><div class="cal-jour"><span class="cal-jour__num">22</span><span class="cal-evt cal-evt--chantier" title="Livraison matériaux Bron">Livraison matériaux Bron</span></div><div class="cal-jour"><span class="cal-jour__num">23</span></div><div class="cal-jour"><span class="cal-jour__num">24</span><span class="cal-evt cal-evt--chantier" title="Fin prévue — Colonne Lyon 8e">Fin prévue — Colonne Lyon 8e</span></div><div class="cal-jour"><span class="cal-jour__num">25</span></div><div class="cal-jour dim"><span class="cal-jour__num">26</span></div><div class="cal-jour"><span class="cal-jour__num">27</span><span class="cal-evt cal-evt--rdv" title="10:00 Visite chauffe-eau LB">10:00 Visite chauffe-eau LB</span></div><div class="cal-jour"><span class="cal-jour__num">28</span></div><div class="cal-jour"><span class="cal-jour__num">29</span></div><div class="cal-jour"><span class="cal-jour__num">30</span></div><div class="cal-jour"><span class="cal-jour__num">31</span><span class="cal-evt cal-evt--chantier" title="Fin prévue — Salle d'eau Bron">Fin prévue — Salle d'eau Bron</span></div><div class="cal-jour hors"><span class="cal-jour__num">1</span></div><div class="cal-jour hors"><span class="cal-jour__num">2</span></div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-12 col-xxl-3 d-grid gap-3 align-content-start">
        <section class="dash-card">
          <div class="dash-card__header"><h2>Jeudi 16 mai</h2><span class="chip chip--en-cours">Aujourd'hui</span></div>
          <div class="planning-item">
            <span class="planning-item__heure">09:00</span>
            <div class="planning-item__corps t-chantier"><b>Suivi chantier — Salle d'eau</b><p>Nadia Karim · Bron · pose du receveur</p></div>
          </div>
          <div class="planning-item">
            <span class="planning-item__heure">14:00</span>
            <div class="planning-item__corps"><b>RDV chantier — Salle de bain</b><p>Sophie Martin · Lyon 3e · validation technique</p></div>
          </div>
          <div class="planning-item">
            <span class="planning-item__heure">17:30</span>
            <div class="planning-item__corps t-relance"><b>Préparer relances devis</b><p>N. Karim (J-2) · C. Petit (J-3)</p></div>
          </div>
        </section>

        <section class="dash-card">
          <div class="dash-card__header"><h2>À venir</h2><a href="#" class="dash-card__lien">Voir tout</a></div>
          <div class="planning-item">
            <span class="planning-item__heure">17/05</span>
            <div class="planning-item__corps"><b>14:00 · Détails techniques</b><p>Sophie Martin · avant démarrage</p></div>
          </div>
          <div class="planning-item">
            <span class="planning-item__heure">22/05</span>
            <div class="planning-item__corps t-chantier"><b>Livraison matériaux</b><p>Chantier salle d'eau · Bron</p></div>
          </div>
          <div class="planning-item">
            <span class="planning-item__heure">03/06</span>
            <div class="planning-item__corps t-chantier"><b>Démarrage CH-2024-015</b><p>Salle de bain · Sophie Martin</p></div>
          </div>
        </section>
      </div>
    </div>

{% endblock %}
