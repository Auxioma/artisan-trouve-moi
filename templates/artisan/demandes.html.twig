{% extends 'artisan/base_artisan.html.twig' %}

{% set menu_actif = 'demandes' %}

{% block title %}Mes demandes{% endblock %}

{% block body %}

    <!-- En-tête -->
    <div class="dash-header">
      <div>
        <h1>Mes demandes</h1>
        <p>3 nouvelles demandes attendent votre réponse — taux de réponse actuel : 92 %.</p>
      </div>
      <div class="dash-header__actions">
        <button class="btn btn-dash-ghost" type="button"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12M8 7l4-4 4 4"/><path d="M4 17v3a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-3"/></svg>Exporter</button>
      </div>
    </div>

    <!-- Onglets de statut -->
    <div class="tabs-statut" role="tablist" aria-label="Filtrer par statut">
      <button class="tabs-statut__onglet actif" type="button" data-filtre="tout" role="tab" aria-selected="true">Toutes <span class="tabs-statut__compteur">8</span></button>
      <button class="tabs-statut__onglet" type="button" data-filtre="nouvelle" role="tab" aria-selected="false">Nouvelles <span class="tabs-statut__compteur">3</span></button>
      <button class="tabs-statut__onglet" type="button" data-filtre="repondue" role="tab" aria-selected="false">Répondues <span class="tabs-statut__compteur">2</span></button>
      <button class="tabs-statut__onglet" type="button" data-filtre="devis" role="tab" aria-selected="false">Devis envoyé <span class="tabs-statut__compteur">2</span></button>
      <button class="tabs-statut__onglet" type="button" data-filtre="expiree" role="tab" aria-selected="false">Expirées <span class="tabs-statut__compteur">1</span></button>
    </div>

    <!-- Filtres -->
    <div class="filtres">
      <div class="filtres__recherche">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
        <input type="search" id="recherche-demandes" placeholder="Rechercher par titre, client ou ville…" aria-label="Rechercher dans les demandes">
      </div>
      <select class="form-select" aria-label="Filtrer par catégorie">
        <option>Toutes les catégories</option>
        <option>Salle de bain</option>
        <option>Dépannage / fuite</option>
        <option>Chauffage / chauffe-eau</option>
        <option>Débouchage</option>
      </select>
      <select class="form-select" aria-label="Trier">
        <option>Plus récentes d'abord</option>
        <option>Plus anciennes d'abord</option>
        <option>Urgentes d'abord</option>
        <option>Budget décroissant</option>
      </select>
    </div>

