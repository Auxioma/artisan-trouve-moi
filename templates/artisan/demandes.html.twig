{% block javascripts %}
{{ parent() }}
<script>
// ============ Filtrage par onglet + recherche ============
const onglets = document.querySelectorAll('.tabs-statut__onglet');
const cartes = document.querySelectorAll('.carte-demande');
const champRecherche = document.getElementById('recherche-demandes');
const etatVide = document.getElementById('etat-vide');
let filtreActif = 'tout';

function appliquerFiltres() {
  const terme = champRecherche.value.trim().toLowerCase();
  let visibles = 0;
  cartes.forEach(c => {
    const okStatut = filtreActif === 'tout' || c.dataset.statut === filtreActif;
    const okTexte = !terme || c.dataset.texte.includes(terme);
    const visible = okStatut && okTexte;
    c.classList.toggle('d-none', !visible);
    if (visible) visibles++;
  });
  etatVide.classList.toggle('d-none', visibles > 0);
}

onglets.forEach(o => o.addEventListener('click', () => {
  onglets.forEach(x => { x.classList.toggle('actif', x === o); x.setAttribute('aria-selected', x === o); });
  filtreActif = o.dataset.filtre;
  appliquerFiltres();
}));

champRecherche.addEventListener('input', appliquerFiltres);
</script>
{% endblock %}
