{% block javascripts %}
{{ parent() }}
<script>
// ============ Filtrage par onglet + recherche ============
const onglets = document.querySelectorAll('.tabs-statut__onglet');
const elements = document.querySelectorAll('[data-statut]');
const champRecherche = document.getElementById('recherche');
const etatVide = document.getElementById('etat-vide');
let filtreActif = 'tout';

function appliquerFiltres() {
  const terme = champRecherche ? champRecherche.value.trim().toLowerCase() : '';
  let visibles = 0;
  elements.forEach(e => {
    const okStatut = filtreActif === 'tout' || e.dataset.statut.split(' ').includes(filtreActif);
    const okTexte = !terme || e.dataset.texte.includes(terme);
    const visible = okStatut && okTexte;
    e.classList.toggle('d-none', !visible);
    if (visible) visibles++;
  });
  if (etatVide) etatVide.classList.toggle('d-none', visibles > 0);
}

onglets.forEach(o => o.addEventListener('click', () => {
  onglets.forEach(x => { x.classList.toggle('actif', x === o); x.setAttribute('aria-selected', x === o); });
  filtreActif = o.dataset.filtre;
  appliquerFiltres();
}));
if (champRecherche) champRecherche.addEventListener('input', appliquerFiltres);
</script>
{% endblock %}
