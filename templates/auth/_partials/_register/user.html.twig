{{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}

<div class="auth-field">
	<label class="form-label" for="email">Adresse e-mail</label>
	<div class="auth-input-group">
		<span class="auth-input-group__icon">
			<svg width="15" height="15" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 6 10-6"/></svg>
		</span>
    {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control', 'id': 'email', 'placeholder': 'vous@exemple.fr', 'autocomplete': 'username', 'required': 'required'}}) }}
	</div>
</div>

<div class="auth-field">
	<label class="form-label" for="mot-de-passe">Mot de passe</label>
	<div class="auth-input-group auth-input-group--toggle">
		<span class="auth-input-group__icon">
			<svg width="15" height="15" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="10" width="18" height="11" rx="2"/><path d="M7 10V7a5 5 0 0 1 10 0v3"/></svg>
		</span>
    {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control', 'id': 'mot-de-passe', 'placeholder': '8 caractères minimum', 'autocomplete': 'new-password', 'required': 'required', 'aria-describedby': 'regles-mdp'}}) }}
		<button class="auth-input-group__toggle" type="button" aria-label="Afficher le mot de passe">
			<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>
		</button>
	</div>
	<span class="auth-capslock">
		<svg width="12" height="12" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3 2 20h20z"/><path d="M12 10v4M12 17h.01"/></svg>Verr. Maj activée</span>
	<div class="auth-strength" data-niveau="0" aria-hidden="true">
		<span class="auth-strength__bars">
			<i></i>
			<i></i>
			<i></i>
			<i></i>
		</span>
		<span class="auth-strength__label"></span>
	</div>
	<div class="auth-rules" id="regles-mdp">
		<span class="auth-rules__item" data-regle="longueur">
			<span class="auth-rules__dot">
				<svg width="9" height="9" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
			</span>8 caractères min.</span>
		<span class="auth-rules__item" data-regle="majuscule">
			<span class="auth-rules__dot">
				<svg width="9" height="9" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
			</span>Une majuscule</span>
		<span class="auth-rules__item" data-regle="chiffre">
			<span class="auth-rules__dot">
				<svg width="9" height="9" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
			</span>Un chiffre</span>
		<span class="auth-rules__item" data-regle="special">
			<span class="auth-rules__dot">
				<svg width="9" height="9" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
			</span>Un caractère spécial</span>
	</div>
</div>

<div class="form-check mb-3 mt-2">
  {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'form-check-input', 'id': 'cgu', 'required': 'required'}}) }}
	<label class="form-check-label small" for="cgu">J'accepte les
		<a href="trouvemoi-cgu.html">conditions générales</a>
		et la
		<a href="trouvemoi-confidentialite.html">politique de confidentialité</a>.</label>
</div>

<button class="btn-auth-primary" type="submit" id="btn-inscription-client">Créer mon compte
	<svg width="15" height="15" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
</button>
<button class="btn-auth-cta d-none" type="submit" id="btn-inscription-pro">Créer mon compte professionnel
	<svg width="15" height="15" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
</button>
{{ form_end(registrationForm) }}
