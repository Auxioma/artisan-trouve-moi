
        {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}
          <div class="auth-pro-fields"><div>
            <div class="row g-2">
              <div class="col-7">
                <div class="auth-field">
                  <label class="form-label" for="entreprise">Nom de l'entreprise</label>
