<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Créer un compte — TrouveMoi Prestataires</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700;12..96,800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="css/auth.css">
</head>
<body class="auth-body">

  <div class="auth-layout">
    <aside class="auth-brand d-none d-lg-flex" aria-hidden="true">
      <a href="trouvemoi-accueil.html" class="auth-brand__logo">
        <svg width="42" height="42" viewBox="0 0 48 48" fill="none" aria-hidden="true"><path d="M24 4C14.6 4 7 11.6 7 21c0 11.8 17 23 17 23s17-11.2 17-23C41 11.6 33.4 4 24 4z" fill="#FF8A1E" stroke="#0A1633" stroke-width="3.4" stroke-linejoin="round"/><circle cx="24" cy="20.5" r="6.6" fill="#fff"/></svg>
        <span><span class="auth-brand__name">TrouveMoi</span><br><span class="auth-brand__sub">Prestataires</span></span>
      </a>

      <div class="auth-brand__body">
        <span class="auth-eyebrow"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2 4 14h6l-1 8 9-12h-6z"/></svg>Inscription en 2 minutes</span>
        <h1 class="auth-brand__title">Rejoignez la communauté qui fait <em>avancer vos projets</em>.</h1>
        <p class="auth-brand__copy">Particulier ou professionnel : un seul compte pour demander des devis ou développer votre activité.</p>

        <!-- Aperçu produit — pur CSS, aucun visuel externe -->
        <div class="auth-preview">
          <div class="preview-card preview-card--demande">
            <span class="preview-card__thumb"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.8"/><path d="m21 15-4.5-4.5L6 21"/></svg></span>
            <span class="preview-card__lines">
              <i class="ph-line ph-line--fonce ph-line--70"></i>
              <i class="ph-line"></i>
              <i class="ph-line ph-line--45"></i>
            </span>
            <span class="preview-card__badge">NOUVELLE DEMANDE</span>
          </div>
          <div class="preview-card preview-card--note">
            <span class="preview-card__note">4,8<small>/5</small></span>
            <span class="preview-card__stars"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg></span>
            <span class="preview-card__sub">256 avis vérifiés</span>
          </div>
          <div class="preview-card preview-card--devis">
            <span class="preview-card__icone"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg></span>
            <span><b>Devis accepté</b><span>2 850 € · Rénovation salle de bain</span></span>
          </div>
        </div>
      </div>

      <div class="auth-brand__stats">
        <div class="auth-stat"><b>+ 120 000</b><span>prestataires vérifiés</span></div>
        <div class="auth-stat"><b>4,8<em>/5</em></b><span>note moyenne</span></div>
        <div class="auth-stat"><b>0 %</b><span>de commission</span></div>
      </div>

      <figure class="auth-brand__quote">
        <span class="auth-avatar auth-avatar--safran">SM</span>
        <p>&ldquo;J'ai trouvé mon plombier en une soirée, devis le lendemain, chantier impeccable.&rdquo; — <b>Sophie M., Lyon</b></p>
      </figure>
    </aside>

    <main class="auth-panel">
      <div class="auth-card auth-card--large">
        <div class="auth-card__header">
          <h2>Créer votre compte</h2>
          <p>Gratuit pour les particuliers, sans engagement pour les pros.</p>
        </div>

        <div class="auth-switch" data-profil="client" role="group" aria-label="Type de compte">
          <button class="auth-switch__option" type="button" data-choix="client" aria-pressed="true"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 3.6-6 8-6s8 2 8 6"/></svg>Particulier</button>
          <button class="auth-switch__option" type="button" data-choix="pro" aria-pressed="false"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="8" width="18" height="13" rx="2"/><path d="M9 8V6a3 3 0 0 1 6 0v2M3 13h18"/></svg>Professionnel</button>
        </div>

        <form action="#" method="post" novalidate>
          <div class="auth-pro-fields"><div>
            <div class="row g-2">
              <div class="col-7">
                <div class="auth-field">
                  <label class="form-label" for="entreprise">Nom de l'entreprise</label>
                  <div class="auth-input-group">
                    <span class="auth-input-group__icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16M8 7h2M8 11h2M8 15h2M13 7h1M13 11h1M16 9h4v12M18 13h.01M18 17h.01"/><path d="M2 21h20"/></svg></span>
                    <input type="text" class="form-control" id="entreprise" name="entreprise" placeholder="Plomberie Express" autocomplete="organization">
                  </div>
                </div>
              </div>
              <div class="col-5">
                <div class="auth-field">
                  <label class="form-label" for="siret">SIRET</label>
                  <input type="text" class="form-control" id="siret" name="siret" placeholder="812 345 678 00015" inputmode="numeric" style="height:48px">
                </div>
              </div>
            </div>
          </div></div>

          <div class="row g-2">
            <div class="col-6">
              <div class="auth-field">
                <label class="form-label" for="prenom">Prénom</label>
                <input type="text" class="form-control" id="prenom" name="prenom" placeholder="Sophie" autocomplete="given-name" required style="height:48px">
              </div>
            </div>
            <div class="col-6">
              <div class="auth-field">
                <label class="form-label" for="nom">Nom</label>
                <input type="text" class="form-control" id="nom" name="nom" placeholder="Martin" autocomplete="family-name" required style="height:48px">
              </div>
            </div>
          </div>

          <div class="auth-field">
            <label class="form-label" for="email">Adresse e-mail</label>
            <div class="auth-input-group">
              <span class="auth-input-group__icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 6 10-6"/></svg></span>
              <input type="email" class="form-control" id="email" name="email" placeholder="vous@exemple.fr" autocomplete="username" required>
            </div>
          </div>

          <div class="auth-field">
            <label class="form-label" for="mot-de-passe">Mot de passe</label>
            <div class="auth-input-group auth-input-group--toggle">
              <span class="auth-input-group__icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="10" width="18" height="11" rx="2"/><path d="M7 10V7a5 5 0 0 1 10 0v3"/></svg></span>
              <input type="password" class="form-control" id="mot-de-passe" name="password" placeholder="8 caractères minimum" autocomplete="new-password" required aria-describedby="regles-mdp">
              <button class="auth-input-group__toggle" type="button" aria-label="Afficher le mot de passe"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg></button>
            </div>
            <span class="auth-capslock"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3 2 20h20z"/><path d="M12 10v4M12 17h.01"/></svg>Verr. Maj activée</span>
            <div class="auth-strength" data-niveau="0" aria-hidden="true">
              <span class="auth-strength__bars"><i></i><i></i><i></i><i></i></span>
              <span class="auth-strength__label"></span>
            </div>
            <div class="auth-rules" id="regles-mdp">
              <span class="auth-rules__item" data-regle="longueur"><span class="auth-rules__dot"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg></span>8 caractères min.</span>
              <span class="auth-rules__item" data-regle="majuscule"><span class="auth-rules__dot"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg></span>Une majuscule</span>
              <span class="auth-rules__item" data-regle="chiffre"><span class="auth-rules__dot"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg></span>Un chiffre</span>
              <span class="auth-rules__item" data-regle="special"><span class="auth-rules__dot"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg></span>Un caractère spécial</span>
            </div>
          </div>

          <div class="form-check mb-3 mt-2">
            <input class="form-check-input" type="checkbox" id="cgu" required>
            <label class="form-check-label small" for="cgu">J'accepte les <a href="trouvemoi-cgu.html">conditions générales</a> et la <a href="trouvemoi-confidentialite.html">politique de confidentialité</a>.</label>
          </div>

          <button class="btn-auth-primary" type="submit" id="btn-inscription-client">Créer mon compte <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg></button>
          <button class="btn-auth-cta d-none" type="submit" id="btn-inscription-pro">Créer mon compte professionnel <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg></button>
        </form>

        <p class="auth-card__footer">Déjà inscrit ? <a href="connexion.html">Se connecter</a></p>
      </div>
    </main>
  </div>

<script>
// ---------- Sélecteur de profil ----------
document.querySelectorAll('.auth-switch').forEach(sw => {
  sw.querySelectorAll('.auth-switch__option').forEach(btn => btn.addEventListener('click', () => {
    sw.querySelectorAll('.auth-switch__option').forEach(b => b.setAttribute('aria-pressed', b === btn ? 'true' : 'false'));
    sw.dataset.profil = btn.dataset.choix;
    document.dispatchEvent(new CustomEvent('profil:change', { detail: btn.dataset.choix }));
  }));
});

// ---------- Afficher / masquer le mot de passe ----------
document.querySelectorAll('.auth-input-group__toggle').forEach(t => t.addEventListener('click', () => {
  const champ = t.closest('.auth-input-group').querySelector('input');
  const visible = champ.type === 'text';
  champ.type = visible ? 'password' : 'text';
  t.setAttribute('aria-label', visible ? 'Afficher le mot de passe' : 'Masquer le mot de passe');
}));

// ---------- Détection Verr. Maj ----------
document.querySelectorAll('input[type="password"]').forEach(champ => {
  champ.addEventListener('keyup', e => {
    const alerte = champ.closest('.auth-field') ? champ.closest('.auth-field').querySelector('.auth-capslock') : null;
    if (alerte && e.getModifierState) alerte.classList.toggle('is-visible', e.getModifierState('CapsLock'));
  });
});

// ---------- Jauge de robustesse + règles ----------
const champMdp = document.getElementById('mot-de-passe');
if (champMdp) {
  const jauge = document.querySelector('.auth-strength');
  const label = jauge ? jauge.querySelector('.auth-strength__label') : null;
  const libelles = ['', 'Faible', 'Moyen', 'Bon', 'Excellent'];
  const regles = {
    longueur: v => v.length >= 8,
    majuscule: v => /[A-ZÀ-Ý]/.test(v),
    chiffre: v => /\d/.test(v),
    special: v => /[^A-Za-z0-9À-ÿ]/.test(v),
  };
  champMdp.addEventListener('input', () => {
    const v = champMdp.value;
    let score = 0;
    Object.entries(regles).forEach(([nom, test]) => {
      const ok = test(v);
      if (ok) score++;
      const item = document.querySelector(`[data-regle="${nom}"]`);
      if (item) item.classList.toggle('is-valid', ok);
    });
    if (jauge) jauge.dataset.niveau = v ? score : 0;
    if (label) label.textContent = v ? libelles[score] : '';
  });
}

// ---------- Champs conditionnels professionnels ----------
document.addEventListener('profil:change', e => {
  const pro = e.detail === 'pro';
  document.querySelectorAll('.auth-pro-fields').forEach(z => z.classList.toggle('is-visible', pro));
  const btnClient = document.getElementById('btn-inscription-client');
  const btnPro = document.getElementById('btn-inscription-pro');
  if (btnClient && btnPro) {
    btnClient.classList.toggle('d-none', pro);
    btnPro.classList.toggle('d-none', !pro);
  }
});

</script>
</body>
</html>
