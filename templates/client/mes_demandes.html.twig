{% extends 'client/base_client.html.twig' %}

{% block title %}Mes demandes{% endblock %}

{% set menu_actif = 'demandes' %}

{% block body %}

    <div class="dash-header">
      <div>
        <h1>Mes demandes</h1>
        <p>1 demande active — 4 artisans ont répondu à votre projet de peinture.</p>
      </div>
      <div class="dash-header__actions">
        <button class="btn btn-dash-cta" type="button"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>Nouvelle demande</button>
      </div>
    </div>

    <div class="tabs-statut" role="tablist" aria-label="Filtrer par statut">
      <button class="tabs-statut__onglet actif" type="button" data-filtre="tout" role="tab" aria-selected="true">Toutes <span class="tabs-statut__compteur">3</span></button>
      <button class="tabs-statut__onglet" type="button" data-filtre="active" role="tab" aria-selected="false">En cours <span class="tabs-statut__compteur">1</span></button>
      <button class="tabs-statut__onglet" type="button" data-filtre="attribuee" role="tab" aria-selected="false">Attribuées <span class="tabs-statut__compteur">1</span></button>
      <button class="tabs-statut__onglet" type="button" data-filtre="terminee" role="tab" aria-selected="false">Terminées <span class="tabs-statut__compteur">1</span></button>
    </div>

    <div class="filtres">
      <div class="filtres__recherche">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
        <input type="search" id="recherche" placeholder="Rechercher une demande…" aria-label="Rechercher">
      </div>
    </div>

    <div class="d-grid gap-3">
      <article class="carte-demande" data-statut="active" data-texte="peinture salon couloir lyon">
        <div class="carte-demande__avatar-col"><span class="kpi__icone kpi__icone--safran"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 3a2.8 2.8 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5z"/></svg></span></div>
        <div class="carte-demande__corps">
          <div class="carte-demande__haut">
            <div><h2>Peinture salon &amp; couloir</h2><p class="carte-demande__client">Publiée il y a 2 jours · visible par les artisans de votre zone</p></div>
            <div class="carte-demande__statuts"><span class="chip chip--nouvelle">EN COURS</span></div>
          </div>
          <p class="carte-demande__description">Salon de 24 m² et couloir de 8 m² à repeindre : murs et plafonds, teintes claires, rebouchage de quelques fissures. Meubles déplacés par nos soins.</p>
          <div class="carte-demande__meta">
            <span class="meta-item"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21c4.5-4 7-7.6 7-11a7 7 0 1 0-14 0c0 3.4 2.5 7 7 11z"/><circle cx="12" cy="10" r="2.6"/></svg>Lyon 3e</span>
            <span class="meta-item"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2.5"/><path d="M6 12h.01M18 12h.01"/></svg>Budget&nbsp;: <b>1 500 – 2 200 €</b></span>
            <span class="meta-item"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M8 3v4M16 3v4M3 10h18"/></svg>Souhaité&nbsp;: juin 2024</span>
          </div>
          <div class="carte-demande__pied">
            <span class="meta-item"><span class="pile-avatars"><span class="avatar avatar--vert">AC</span><span class="avatar avatar--violet">DP</span><span class="avatar avatar--bleu">PM</span><span class="pile-avatars__plus">+1</span></span>&nbsp;<b>4 artisans</b>&nbsp;ont répondu · <b>3 devis</b> reçus</span>
            <div class="carte-demande__actions">
              <button class="btn btn-dash-ghost" type="button"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 3a2.8 2.8 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5z"/></svg>Modifier</button>
              <a class="btn btn-dash-primary" href="{{ path('app_client_devis_recus') }}"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v18M8 21h8"/><path d="m5 7 3.5 7a3.5 3.5 0 0 1-7 0zM19 7l3.5 7a3.5 3.5 0 0 1-7 0z"/><path d="M5 7h14"/></svg>Comparer les devis</a>
            </div>
          </div>
        </div>
      </article>

      <article class="carte-demande" data-statut="attribuee" data-texte="renovation salle de bain plomberie express lyon">
        <div class="carte-demande__avatar-col"><span class="avatar avatar--encre">PE</span></div>
        <div class="carte-demande__corps">
          <div class="carte-demande__haut">
            <div><h2>Rénovation complète de salle de bain</h2><p class="carte-demande__client">Attribuée à <b>Plomberie Express</b> <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg> le 16 mai</p></div>
            <div class="carte-demande__statuts"><span class="chip chip--accepte">ATTRIBUÉE</span></div>
          </div>
          <div class="carte-demande__meta">
            <span class="meta-item"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21c4.5-4 7-7.6 7-11a7 7 0 1 0-14 0c0 3.4 2.5 7 7 11z"/><circle cx="12" cy="10" r="2.6"/></svg>Lyon 3e</span>
            <span class="meta-item"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2.5"/><path d="M6 12h.01M18 12h.01"/></svg>Devis accepté&nbsp;: <b>3 450 €</b></span>
            <span class="meta-item"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M8 3v4M16 3v4M3 10h18"/></svg>Travaux&nbsp;: 3 → 14 juin</span>
          </div>
          <div class="carte-demande__pied">
            <span class="carte-chantier__etape"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>RDV de validation technique demain à 14 h</span>
            <div class="carte-demande__actions">
              <a class="btn btn-dash-ghost" href="{{ path('app_client_messages') }}"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12a8 8 0 1 0-3.6 6.7L21 20z"/></svg>Contacter</a>
              <a class="btn btn-dash-primary" href="{{ path('app_client_projets') }}"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>Suivre le projet</a>
            </div>
          </div>
        </div>
      </article>

      <article class="carte-demande est-expiree" data-statut="terminee" data-texte="debouchage evier cuisine plomberie express">
        <div class="carte-demande__avatar-col"><span class="avatar avatar--encre">PE</span></div>
        <div class="carte-demande__corps">
          <div class="carte-demande__haut">
            <div><h2>Débouchage évier de cuisine</h2><p class="carte-demande__client">Réalisée par <b>Plomberie Express</b> · mars 2024 · 180 €</p></div>
            <div class="carte-demande__statuts"><span class="chip chip--termine">TERMINÉE</span></div>
          </div>
          <div class="carte-demande__pied">
            <span class="meta-item">Votre avis&nbsp;: <span class="etoiles"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg></span></span>
            <div class="carte-demande__actions">
              <button class="btn btn-dash-ghost" type="button"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 3H6v18h12V8z"/><path d="M13 3v5h5M9 13h6M9 17h4"/></svg>Voir la facture</button>
            </div>
          </div>
        </div>
      </article>

      <div class="etat-vide d-none" id="etat-vide">
        <span class="etat-vide__icone"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 8 12 3 3 8v8l9 5 9-5z"/><path d="M3 8l9 5 9-5M12 13v8"/></svg></span>
        <b>Aucune demande ne correspond</b>
        <p>Modifiez votre recherche ou changez d'onglet.</p>
      </div>
    </div>

{% endblock %}

{% block javascripts %}
<script>
// ============ Filtrage par onglet + recherche ============
const onglets = document.querySelectorAll('.tabs-statut__onglet');
const elements = document.querySelectorAll('[data-statut]');
const champRecherche = document.getElementById('recherche');
const etatVide = document.getElementById('etat-vide');
let filtreActif = 'tout';
function appliquerFiltres() {
  const terme = champRecherche ? champRecherche.value.trim().toLowerCase() : '';
  let visibles = 0;
  elements.forEach(e => {
    const okStatut = filtreActif === 'tout' || e.dataset.statut.split(' ').includes(filtreActif);
    const okTexte = !terme || e.dataset.texte.includes(terme);
    const visible = okStatut && okTexte;
    e.classList.toggle('d-none', !visible);
    if (visible) visibles++;
  });
  if (etatVide) etatVide.classList.toggle('d-none', visibles > 0);
}
onglets.forEach(o => o.addEventListener('click', () => {
  onglets.forEach(x => { x.classList.toggle('actif', x === o); x.setAttribute('aria-selected', x === o); });
  filtreActif = o.dataset.filtre;
  appliquerFiltres();
}));
if (champRecherche) champRecherche.addEventListener('input', appliquerFiltres);
</script>
{% endblock %}
