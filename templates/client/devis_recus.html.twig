{% extends 'client/base_client.html.twig' %}

{% block title %}Devis reçus{% endblock %}

{% set menu_actif = 'devis' %}

{% block body %}

    <div class="dash-header">
      <div>
        <h1>Devis reçus</h1>
        <p>3 devis pour votre demande « Peinture salon &amp; couloir » — comparez avant de choisir.</p>
      </div>
      <div class="dash-header__actions">
        <select class="form-select w-auto" aria-label="Choisir la demande">
          <option selected>Peinture salon &amp; couloir (3 devis)</option>
          <option>Rénovation salle de bain (attribuée)</option>
        </select>
      </div>
    </div>

    <div class="row g-3 pt-2 mb-4">
      <div class="col-12 col-md-4">
        <div class="devis-comp devis-comp--meilleur">
          <span class="devis-comp__badge">MEILLEURE OFFRE</span>
          <div class="carte-artisan border-0 p-0">
            <span class="avatar avatar--vert">AC</span>
            <div class="carte-artisan__corps">
              <b>Atelier Couleurs <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg></b>
              <p><span class="note"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg>4,9</span> · 143 avis · Lyon 6e</p>
            </div>
          </div>
          <div class="devis-comp__montant">1 690 €<small> TTC</small></div>
          <div class="devis-comp__details">
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>Durée des travaux<b>4 jours</b></span>
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M8 3v4M16 3v4M3 10h18"/></svg>Peut démarrer<b>10 juin</b></span>
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-3.5 8-10V5l-8-3-8 3v7c0 6.5 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>Garantie<b>2 ans</b></span>
          </div>
          <div class="devis-comp__actions">
            <button class="btn btn-dash-primary" type="button"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>Accepter ce devis</button>
            <button class="btn btn-dash-ghost" type="button"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 3H6v18h12V8z"/><path d="M13 3v5h5M9 13h6M9 17h4"/></svg>Voir le détail (PDF)</button>
            <a class="btn btn-dash-ghost" href="{{ path('app_client_messages') }}"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12a8 8 0 1 0-3.6 6.7L21 20z"/></svg>Poser une question</a>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-4">
        <div class="devis-comp">
          
          <div class="carte-artisan border-0 p-0">
            <span class="avatar avatar--violet">DP</span>
            <div class="carte-artisan__corps">
              <b>DécoPro Lyon <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg></b>
              <p><span class="note"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg>4,7</span> · 89 avis · Villeurbanne</p>
            </div>
          </div>
          <div class="devis-comp__montant">1 850 €<small> TTC</small> <span class="chip chip--nouveau">NOUVEAU</span></div>
          <div class="devis-comp__details">
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>Durée des travaux<b>3 jours</b></span>
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M8 3v4M16 3v4M3 10h18"/></svg>Peut démarrer<b>5 juin</b></span>
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-3.5 8-10V5l-8-3-8 3v7c0 6.5 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>Garantie<b>1 an</b></span>
          </div>
          <div class="devis-comp__actions">
            <button class="btn btn-dash-primary" type="button"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>Accepter ce devis</button>
            <button class="btn btn-dash-ghost" type="button"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 3H6v18h12V8z"/><path d="M13 3v5h5M9 13h6M9 17h4"/></svg>Voir le détail (PDF)</button>
            <a class="btn btn-dash-ghost" href="{{ path('app_client_messages') }}"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12a8 8 0 1 0-3.6 6.7L21 20z"/></svg>Poser une question</a>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-4">
        <div class="devis-comp">
          
          <div class="carte-artisan border-0 p-0">
            <span class="avatar avatar--bleu">PM</span>
            <div class="carte-artisan__corps">
              <b>Peintures Morel <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg></b>
              <p><span class="note"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg>4,8</span> · 210 avis · Lyon 3e</p>
            </div>
          </div>
          <div class="devis-comp__montant">2 100 €<small> TTC</small></div>
          <div class="devis-comp__details">
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>Durée des travaux<b>5 jours</b></span>
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M8 3v4M16 3v4M3 10h18"/></svg>Peut démarrer<b>17 juin</b></span>
            <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-3.5 8-10V5l-8-3-8 3v7c0 6.5 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>Garantie<b>2 ans</b></span>
          </div>
          <div class="devis-comp__actions">
            <button class="btn btn-dash-primary" type="button"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>Accepter ce devis</button>
            <button class="btn btn-dash-ghost" type="button"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 3H6v18h12V8z"/><path d="M13 3v5h5M9 13h6M9 17h4"/></svg>Voir le détail (PDF)</button>
            <a class="btn btn-dash-ghost" href="{{ path('app_client_messages') }}"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12a8 8 0 1 0-3.6 6.7L21 20z"/></svg>Poser une question</a>
          </div>
        </div>
      </div>
    </div>

    <div class="conseil mb-4">
      <p class="conseil__titre mb-0"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18h6M10 21h4"/><path d="M12 3a6 6 0 0 0-3.5 10.9c.9.7 1.5 1.3 1.5 2.1h4c0-.8.6-1.4 1.5-2.1A6 6 0 0 0 12 3z"/></svg>Bien comparer</p>
      <p>Ne regardez pas que le prix : vérifiez la durée, la garantie et lisez les derniers avis. Vous pouvez poser vos questions à chaque artisan avant d'accepter — c'est gratuit et sans engagement.</p>
    </div>

    <div class="dash-card__header"><h2 class="h5 mb-0">Devis déjà acceptés</h2></div>
    <div class="dash-card mt-2">
      <div class="devis-recu border-0 py-1">
        <span class="avatar avatar--encre">PE</span>
        <div class="devis-recu__corps">
          <b>Plomberie Express — Rénovation salle de bain</b>
          <p>DEV-2024-058 · accepté le 16 mai 2024 · travaux du 3 au 14 juin</p>
        </div>
        <div class="devis-recu__fin">
          <span class="devis-montant">3 450 €</span>
          <span class="chip chip--accepte">ACCEPTÉ</span>
        </div>
      </div>
    </div>

{% endblock %}
