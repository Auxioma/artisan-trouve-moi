            <button class="btn btn-dash-ghost" type="button"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>Voir le profil</button>
            <button class="btn btn-dash-cta" type="button"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 3H6v18h12V8z"/><path d="M13 3v5h5M9 13h6M9 17h4"/></svg>Demander un devis</button>
          </div>
        </div>
      </article>
    </div>

    <nav class="dash-pagination" aria-label="Pagination des résultats">
      <p class="dash-pagination__info mb-0">Affichage de <b>1 – 6</b> sur <b>48</b> artisans</p>
      <div class="dash-pagination__pages">
        <button class="dash-pagination__page actif" type="button" aria-current="page">1</button>
        <button class="dash-pagination__page" type="button">2</button>
        <button class="dash-pagination__page" type="button">3</button>
        <button class="dash-pagination__page" type="button">…</button>
        <button class="dash-pagination__page" type="button">8</button>
      </div>
    </nav>

{% endblock %}

{% block javascripts %}
<script>
document.querySelectorAll('.btn-coeur').forEach(b => b.addEventListener('click', () => {
  b.classList.toggle('est-favori');
  const fav = b.classList.contains('est-favori');
  b.setAttribute('aria-label', fav ? 'Retirer des favoris' : 'Ajouter aux favoris');
}));
</script>
{% endblock %}
