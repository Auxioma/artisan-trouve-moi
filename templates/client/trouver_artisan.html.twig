{% extends 'client/base_client.html.twig' %}

{% block title %}Trouver un artisan{% endblock %}

{% set menu_actif = 'trouver' %}

{% block body %}

    <div class="dash-header">
      <div>
        <h1>Trouver un artisan</h1>
        <p>120 000 prestataires vérifiés — identité, SIRET et assurances contrôlés.</p>
      </div>
    </div>

    <div class="dash-card mb-3">
      <div class="recherche-artisan">
        <div class="filtres__recherche mw-100">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="search" id="recherche" placeholder="Quel artisan ? (peintre, plombier, électricien…)" aria-label="Métier recherché">
        </div>
        <div class="filtres__recherche mw-100">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21c4.5-4 7-7.6 7-11a7 7 0 1 0-14 0c0 3.4 2.5 7 7 11z"/><circle cx="12" cy="10" r="2.6"/></svg>
          <input type="search" value="Lyon 3e (69003)" aria-label="Localisation">
        </div>
        <select class="form-select" aria-label="Rayon">
          <option>10 km</option>
          <option selected>25 km</option>
          <option>50 km</option>
        </select>
        <button class="btn btn-dash-cta" type="button"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>Rechercher</button>
      </div>
      <div class="categories-rapides">
        <button class="categorie-rapide est-actif" type="button">Peinture</button>
        <button class="categorie-rapide" type="button">Plomberie</button>
        <button class="categorie-rapide" type="button">Électricité</button>
        <button class="categorie-rapide" type="button">Menuiserie</button>
        <button class="categorie-rapide" type="button">Maçonnerie</button>
        <button class="categorie-rapide" type="button">Jardin</button>
        <button class="categorie-rapide" type="button">Rénovation complète</button>
      </div>
    </div>

    <div class="filtres">
      <span class="small fw-bold text-dark me-1">6 artisans trouvés</span>
      <select class="form-select ms-auto" aria-label="Note minimale">
        <option>Toutes les notes</option>
        <option selected>4 ★ et plus</option>
        <option>4,5 ★ et plus</option>
      </select>
      <select class="form-select" aria-label="Disponibilité">
        <option selected>Toutes disponibilités</option>
        <option>Sous 48 h</option>
        <option>Cette semaine</option>
      </select>
      <select class="form-select" aria-label="Trier">
        <option selected>Pertinence</option>
        <option>Note décroissante</option>
        <option>Distance croissante</option>
        <option>Nombre d'avis</option>
      </select>
    </div>

    <div class="d-grid gap-3">
      <article class="resultat-artisan" data-texte="atelier couleurs peinture &amp; décoration lyon 6e">
        <span class="avatar avatar--lg avatar--vert">AC</span>
        <div class="resultat-artisan__corps">
          <div class="resultat-artisan__nom"><b>Atelier Couleurs</b><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg> <span class="chip chip--premium">EXCELLENCE</span></div>
          <p class="resultat-artisan__sous">
            <span>Peinture &amp; décoration</span>
            <span class="note"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg>4,9</span><span>(143 avis)</span>
            <span><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21c4.5-4 7-7.6 7-11a7 7 0 1 0-14 0c0 3.4 2.5 7 7 11z"/><circle cx="12" cy="10" r="2.6"/></svg>Lyon 6e · 3,2 km</span>
          </p>
          <p class="resultat-artisan__desc">Peintres décorateurs depuis 2015. Finitions soignées, chantiers propres, conseils couleurs offerts. Devis détaillé sous 48 h.</p>
