          <div class="resultat-artisan__tags"><span class="chip">Salle de bain</span><span class="chip">Dépannage</span><span class="chip">Chauffe-eau</span></div>
        </div>
        <div class="resultat-artisan__fin">
          <button class="btn-coeur est-favori" type="button" aria-label="Retirer des favoris"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21C7 16.5 2 13 2 8.5A4.5 4.5 0 0 1 6.5 4c2 0 3.7 1 5.5 3 1.8-2 3.5-3 5.5-3A4.5 4.5 0 0 1 22 8.5c0 4.5-5 8-10 12.5z"/></svg></button>
          <span class="resultat-artisan__reponse"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2 4 14h6l-1 8 9-12h-6z"/></svg>Répond en ~ 1 h</span>
          <div class="resultat-artisan__actions">
            <button class="btn btn-dash-ghost" type="button"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>Voir le profil</button>
            <button class="btn btn-dash-cta" type="button"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 3H6v18h12V8z"/><path d="M13 3v5h5M9 13h6M9 17h4"/></svg>Demander un devis</button>
          </div>
        </div>
      </article>
