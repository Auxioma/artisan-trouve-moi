{% block javascripts %}
<script>
document.querySelectorAll('.btn-coeur').forEach(b => b.addEventListener('click', () => {
  b.classList.toggle('est-favori');
  const fav = b.classList.contains('est-favori');
  b.setAttribute('aria-label', fav ? 'Retirer des favoris' : 'Ajouter aux favoris');
}));
</script>
{% endblock %}
