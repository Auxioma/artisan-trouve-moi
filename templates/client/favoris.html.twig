{% extends 'client/base_client.html.twig' %}

{% block title %}Mes favoris{% endblock %}

{% set menu_actif = 'favoris' %}

{% block body %}

    <div class="dash-header">
      <div>
        <h1>Mes favoris</h1>
        <p>4 artisans enregistrés — contactez-les directement pour vos prochains projets.</p>
      </div>
      <div class="dash-header__actions">
        <a class="btn btn-dash-ghost" href="{{ path('client_trouver_artisan') }}"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>Trouver d'autres artisans</a>
      </div>
    </div>

    <div class="d-grid gap-3">
      <article class="resultat-artisan" data-texte="plomberie express plomberie &amp; chauffage lyon 3e">
        <span class="avatar avatar--lg avatar--encre">PE</span>
        <div class="resultat-artisan__corps">
          <div class="resultat-artisan__nom"><b>Plomberie Express</b><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg> <span class="chip chip--premium">EXCELLENCE</span></div>
          <p class="resultat-artisan__sous">
            <span>Plomberie &amp; chauffage</span>
            <span class="note"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg>4,8</span><span>(256 avis)</span>
