{% extends 'client/base_client.html.twig' %}

{% block title %}Mon espace{% endblock %}

{% set menu_actif = 'dashboard' %}

{% block body %}

    <!-- En-tête -->
    <div class="dash-header">
      <div>
        <h1>Bonjour Sophie</h1>
        <p>Jeudi 16 mai 2024 — votre projet de salle de bain démarre dans 18 jours.</p>
      </div>
      <div class="dash-header__actions">
        <button class="btn btn-dash-cta" type="button"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>Nouvelle demande</button>
      </div>
    </div>

    <!-- ============ KPI ============ -->
    <div class="row g-3 mb-4">
      <div class="col-6 col-lg-3">
        <div class="kpi">
          <span class="kpi__icone kpi__icone--bleu"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M8 2v4M16 2v4M7 11h10M7 15h6"/></svg></span>
          <div>
            <div class="kpi__valeur">2</div>
            <div class="kpi__libelle">Demandes actives</div>
            <span class="kpi__delta kpi__delta--neutre">7 artisans ont répondu</span>
          </div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="kpi">
          <span class="kpi__icone kpi__icone--safran"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 3H6v18h12V8z"/><path d="M13 3v5h5M9 13h6M9 17h4"/></svg></span>
          <div>
            <div class="kpi__valeur">3</div>
            <div class="kpi__libelle">Devis reçus</div>
            <span class="kpi__delta"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>1 nouveau aujourd'hui</span>
          </div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="kpi">
          <span class="kpi__icone kpi__icone--vert"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 20h20M4 20V9l8-6 8 6v11"/><path d="M9 20v-6h6v6"/></svg></span>
          <div>
            <div class="kpi__valeur">1</div>
            <div class="kpi__libelle">Projet en cours</div>
            <span class="kpi__delta kpi__delta--neutre">Démarrage le 3 juin</span>
          </div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="kpi">
          <span class="kpi__icone kpi__icone--violet"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21C7 16.5 2 13 2 8.5A4.5 4.5 0 0 1 6.5 4c2 0 3.7 1 5.5 3 1.8-2 3.5-3 5.5-3A4.5 4.5 0 0 1 22 8.5c0 4.5-5 8-10 12.5z"/></svg></span>
          <div>
            <div class="kpi__valeur">4</div>
            <div class="kpi__libelle">Artisans favoris</div>
            <span class="kpi__delta kpi__delta--neutre">Prêts pour vos projets</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ============ GRILLE PRINCIPALE ============ -->
    <div class="row g-3">

      <!-- Colonne 1 : projet + demandes -->
      <div class="col-12 col-xl-4 d-grid gap-3 align-content-start">
        <section class="dash-card">
          <div class="dash-card__header">
            <h2>Suivi de mon projet</h2>
            <span class="chip chip--planifie">PLANIFIÉ</span>
          </div>
          <div class="carte-artisan border-0 p-0">
            <span class="avatar avatar--encre">PE</span>
            <div class="carte-artisan__corps">
              <b>Rénovation salle de bain</b>
              <p>Plomberie Express <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg> · 3 450 € TTC · Lyon 3e</p>
            </div>
          </div>
          <div class="suivi-etapes">
            <div class="suivi-etape est-fait">
              <span class="suivi-etape__point"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg></span>
              <b>Devis accepté</b><span>16 mai</span>
            </div>
            <div class="suivi-etape est-actif">
              <span class="suivi-etape__point"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg></span>
              <b>Préparation</b><span>en cours</span>
            </div>
            <div class="suivi-etape">
              <span class="suivi-etape__point"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18v3h3l6.3-6.3a4 4 0 0 0 5.4-5.4l-2.8 2.8-2.4-2.4z"/></svg></span>
              <b>Travaux</b><span>3 → 14 juin</span>
            </div>
            <div class="suivi-etape">
              <span class="suivi-etape__point"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z"/></svg></span>
              <b>Livraison</b><span>14 juin</span>
            </div>
          </div>
          <div class="carte-demande__pied mt-2">
            <span class="carte-chantier__etape"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M8 3v4M16 3v4M3 10h18"/></svg>RDV demain 14 h — validation technique</span>
            <div class="carte-demande__actions">
              <button class="btn btn-dash-ghost" type="button"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12a8 8 0 1 0-3.6 6.7L21 20z"/></svg>Contacter</button>
              <button class="btn btn-dash-primary" type="button">Voir le projet</button>
            </div>
          </div>
        </section>

        <section class="dash-card">
          <div class="dash-card__header">
            <h2>Mes demandes</h2>
            <a href="#" class="dash-card__lien">Voir toutes</a>
          </div>
          <div class="ligne-demande">
            <div><b>Peinture salon &amp; couloir</b><p>Lyon 3e — publiée il y a 2 jours</p></div>
            <div class="ligne-demande__fin">
              <span class="chip chip--nouvelle">4 RÉPONSES</span>
              <span class="ligne-demande__chevron"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 6 6 6-6 6"/></svg></span>
            </div>
          </div>
          <div class="ligne-demande">
            <div><b>Rénovation salle de bain</b><p>Lyon 3e — devis accepté le 16 mai</p></div>
            <div class="ligne-demande__fin">
              <span class="chip chip--accepte">ATTRIBUÉE</span>
              <span class="ligne-demande__chevron"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 6 6 6-6 6"/></svg></span>
            </div>
          </div>
        </section>
      </div>

      <!-- Colonne 2 : devis reçus + RDV -->
      <div class="col-12 col-xl-4 d-grid gap-3 align-content-start">
        <section class="dash-card">
          <div class="dash-card__header">
            <h2>Devis reçus — Peinture salon</h2>
            <a href="#" class="dash-card__lien"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v18M8 21h8"/><path d="m5 7 3.5 7a3.5 3.5 0 0 1-7 0zM19 7l3.5 7a3.5 3.5 0 0 1-7 0z"/><path d="M5 7h14"/></svg> Comparer</a>
          </div>
          <div class="devis-recu">
            <span class="avatar avatar--vert">AC</span>
            <div class="devis-recu__corps">
              <b>Atelier Couleurs</b>
              <p><span class="note"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg>4,9</span> · 143 avis · Lyon 6e</p>
            </div>
            <div class="devis-recu__fin">
              <span class="devis-montant">1 690 €</span>
              <span class="chip chip--meilleure">MEILLEURE OFFRE</span>
            </div>
          </div>
          <div class="devis-recu">
            <span class="avatar avatar--violet">DP</span>
            <div class="devis-recu__corps">
              <b>DécoPro Lyon</b>
              <p><span class="note"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg>4,7</span> · 89 avis · Villeurbanne</p>
            </div>
            <div class="devis-recu__fin">
              <span class="devis-montant">1 850 €</span>
              <span class="chip chip--nouveau">NOUVEAU</span>
            </div>
          </div>
          <div class="devis-recu">
            <span class="avatar avatar--bleu">PM</span>
            <div class="devis-recu__corps">
              <b>Peintures Morel</b>
              <p><span class="note"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg>4,8</span> · 210 avis · Lyon 3e</p>
            </div>
            <div class="devis-recu__fin">
              <span class="devis-montant">2 100 €</span>
            </div>
          </div>
        </section>

        <section class="dash-card">
          <div class="dash-card__header">
            <h2>Prochain rendez-vous</h2>
            <a href="#" class="dash-card__lien">Mon agenda</a>
          </div>
          <div class="rdv">
            <b>Demain · 14:00 — Validation technique</b>
            <p>Plomberie Express · à votre domicile, Lyon 3e</p>
          </div>
          <div class="carte-demande__actions mt-3">
            <button class="btn btn-dash-ghost" type="button"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M8 3v4M16 3v4M3 10h18"/></svg>Déplacer</button>
            <button class="btn btn-dash-ghost" type="button"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12a8 8 0 1 0-3.6 6.7L21 20z"/></svg>Poser une question</button>
          </div>
        </section>

        <section class="conseil">
          <p class="conseil__titre mb-0"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18h6M10 21h4"/><path d="M12 3a6 6 0 0 0-3.5 10.9c.9.7 1.5 1.3 1.5 2.1h4c0-.8.6-1.4 1.5-2.1A6 6 0 0 0 12 3z"/></svg>Conseil</p>
          <p>Ajoutez des photos à votre demande de peinture : les demandes illustrées reçoivent des devis 2× plus précis.</p>
          <a href="#">Ajouter des photos <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
        </section>
      </div>

      <!-- Colonne 3 : messages + favoris -->
      <div class="col-12 col-xl-4 d-grid gap-3 align-content-start">
        <section class="dash-card">
          <div class="dash-card__header">
            <h2>Messages récents</h2>
            <a href="#" class="dash-card__lien">Voir tous</a>
          </div>
          <div class="ligne-message">
            <span class="avatar avatar--sm avatar--encre">PE</span>
            <div class="ligne-message__corps"><b>Plomberie Express</b><p>Parfait ! À demain 14 h pour la validation technique.</p></div>
            <span class="ligne-message__fin">
              <span class="ligne-message__quand">10:32</span>
              <span class="ligne-message__pastille">1</span>
            </span>
          </div>
          <div class="ligne-message">
            <span class="avatar avatar--sm avatar--vert">AC</span>
            <div class="ligne-message__corps"><b>Atelier Couleurs</b><p>Bonjour, notre devis détaillé est disponible…</p></div>
            <span class="ligne-message__fin"><span class="ligne-message__quand">09:15</span></span>
          </div>
          <div class="ligne-message">
            <span class="avatar avatar--sm avatar--violet">DP</span>
            <div class="ligne-message__corps"><b>DécoPro Lyon</b><p>Nous pouvons passer voir le salon jeudi si…</p></div>
            <span class="ligne-message__fin"><span class="ligne-message__quand">Hier</span></span>
          </div>
        </section>

        <section class="dash-card">
          <div class="dash-card__header">
            <h2>Mes artisans favoris</h2>
            <a href="#" class="dash-card__lien">Voir tous</a>
          </div>
          <div class="carte-artisan">
            <span class="avatar avatar--encre">PE</span>
            <div class="carte-artisan__corps">
              <b>Plomberie Express <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg></b>
              <p><span class="note"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg>4,8</span> · Plomberie · Lyon 3e</p>
            </div>
            <button class="btn btn-dash-ghost btn-sm" type="button">Demander</button>
          </div>
          <div class="carte-artisan">
            <span class="avatar avatar--bleu">EL</span>
            <div class="carte-artisan__corps">
              <b>Élec+ Lyon <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg></b>
              <p><span class="note"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg>4,9</span> · Électricité · Lyon 7e</p>
            </div>
            <button class="btn btn-dash-ghost btn-sm" type="button">Demander</button>
          </div>
          <div class="carte-artisan">
            <span class="avatar avatar--vert">AC</span>
            <div class="carte-artisan__corps">
              <b>Atelier Couleurs <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg></b>
              <p><span class="note"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg>4,9</span> · Peinture · Lyon 6e</p>
            </div>
            <button class="btn btn-dash-ghost btn-sm" type="button">Demander</button>
          </div>
          <div class="carte-artisan">
            <span class="avatar avatar--violet">MB</span>
            <div class="carte-artisan__corps">
              <b>Menuiserie Blanc <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg></b>
              <p><span class="note"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg>4,7</span> · Menuiserie · Caluire</p>
            </div>
            <button class="btn btn-dash-ghost btn-sm" type="button">Demander</button>
          </div>
        </section>
      </div>

    </div>
{% endblock %}
