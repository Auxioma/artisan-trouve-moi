{# ============================================================
   Layout de base — Espace client TrouveMoi
   Chaque page enfant définit : title, menu_actif, body, javascripts
   ============================================================ #}
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% block title %}Mon espace{% endblock %} — TrouveMoi</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700;12..96,800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="{{ asset('styles/dashboard/dashboard.css') }}">
{% block stylesheets %}{% endblock %}
</head>
<body class="dash-body">

<div class="dash-layout">

  {% include 'client/_topbar.html.twig' %}

  {% include 'client/_sidebar.html.twig' %}

  <!-- ============ PANNEAU PRINCIPAL ============ -->
  <main class="dash-panel">
{% block body %}{% endblock %}
  </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
