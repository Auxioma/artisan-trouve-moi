{# ============================================================
   Sidebar de l'espace client
   Requiert : menu_actif ('dashboard'|'demandes'|'devis'|'projets'|
              'messages'|'avis'|'trouver'|'favoris'|'parametres')
   ============================================================ #}
  <aside class="sidebar offcanvas-lg offcanvas-start" tabindex="-1" id="sidebar" aria-label="Navigation principale">
    <div class="sidebar__profil">
      <span class="avatar avatar--lg avatar--safran">SM</span>
      <div>
        <b>Sophie Martin</b>
        <span class="chip chip--verifie"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg>Profil vérifié</span>
      </div>
    </div>

    <p class="sidebar__label">Principal</p>
    <nav class="sidebar__nav" aria-label="Sections principales">
          <a href="{{ path('client_dashboard') }}" class="sidebar__link{% if menu_actif == 'dashboard' %} actif{% endif %}"{% if menu_actif == 'dashboard' %} aria-current="page"{% endif %}><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>Tableau de bord</a>
