          <a href="{{ path('client_devis_recus') }}" class="sidebar__link{% if menu_actif == 'devis' %} actif{% endif %}"{% if menu_actif == 'devis' %} aria-current="page"{% endif %}><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 3H6v18h12V8z"/><path d="M13 3v5h5M9 13h6M9 17h4"/></svg>Devis reçus<span class="sidebar__badge">3</span></a>
          <a href="{{ path('client_projets') }}" class="sidebar__link{% if menu_actif == 'projets' %} actif{% endif %}"{% if menu_actif == 'projets' %} aria-current="page"{% endif %}><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 20h20M4 20V9l8-6 8 6v11"/><path d="M9 20v-6h6v6"/></svg>Mes projets</a>
          <a href="{{ path('client_messages') }}" class="sidebar__link{% if menu_actif == 'messages' %} actif{% endif %}"{% if menu_actif == 'messages' %} aria-current="page"{% endif %}><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12a8 8 0 1 0-3.6 6.7L21 20z"/></svg>Messages<span class="sidebar__badge">1</span></a>
          <a href="{{ path('client_avis') }}" class="sidebar__link{% if menu_actif == 'avis' %} actif{% endif %}"{% if menu_actif == 'avis' %} aria-current="page"{% endif %}><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z"/></svg>Mes avis</a>
