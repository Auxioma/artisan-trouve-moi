{% extends 'client/base_client.html.twig' %}

{% block title %}Paramètres{% endblock %}

{% set menu_actif = 'parametres' %}

{% block body %}
    {{ form_start(form) }}

    <div class="dash-header">
        <div>
            <h1>Paramètres</h1>
            <p>Gérez vos informations personnelles, vos notifications et la confidentialité de votre compte.</p>
        </div>
        <div class="dash-header__actions">
            <button class="btn btn-dash-primary" type="submit"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 5-5.5"/></svg>Enregistrer les modifications</button>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12 col-lg-3">
            <nav class="param-nav" aria-label="Sections des paramètres">
                <button class="param-nav__lien actif" type="button" data-panneau="profil"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 3.6-6 8-6s8 2 8 6"/></svg>Mon profil</button>
                <button class="param-nav__lien" type="button" data-panneau="notifications"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>Notifications</button>
                <button class="param-nav__lien" type="button" data-panneau="confidentialite"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-3.5 8-10V5l-8-3-8 3v7c0 6.5 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>Confidentialité</button>
                <button class="param-nav__lien" type="button" data-panneau="securite"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="10" width="18" height="11" rx="2"/><path d="M7 10V7a5 5 0 0 1 10 0v3"/></svg>Sécurité</button>
            </nav>
        </div>

        <div class="col-12 col-lg-9">
            <div class="param-panneau actif" id="panneau-profil">
                <div class="dash-card">
                    <p class="param-section-titre">Informations personnelles</p>
                    <div class="param-logo mb-3">
  <span class="avatar avatar--lg avatar--safran" id="avatar-apercu-initiales"
        {% if app.user.avatarFilename %}style="display:none;"{% endif %}>
    {{ (app.user.firstName|first ~ app.user.lastName|first)|upper }}
  </span>

                        <img id="avatar-apercu-image"
                             class="avatar avatar--lg"
                             alt="Photo de profil"
                            {% if app.user.avatarFilename %}
                            src="{{ vich_uploader_asset(app.user, 'avatarFile') }}"
                        {% else %}
                            src="" style="display:none;"
                            {% endif %}>

                        <div>
                            <div class="d-flex gap-2 flex-wrap">
                                <button class="btn btn-dash-ghost btn-sm" type="button" id="btn-changer-photo">Changer la photo</button>
                                <button class="btn btn-dash-ghost btn-sm" type="button" id="btn-supprimer-photo">Supprimer</button>
                            </div>
                            <p>PNG ou JPG, 2 Mo max. Seules vos initiales sont visibles par défaut.</p>

                            {# input file réel, masqué #}
                            <div class="d-none">
                                {{ form_widget(form.avatarFile.file, {
                                    id: 'avatar-input-file',
                                    attr: {
                                        accept: 'image/png,image/jpeg'
                                    }
                                }) }}
                                {% if form.avatarFile.delete is defined %}
                                    {{ form_widget(form.avatarFile.delete, { attr: { id: 'avatar-input-delete' } }) }}
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="prenom">Prénom</label>
                            {{ form_widget(form.firstName, {
                                label: 'Prénom',
                                attr: {
                                    class: 'form-control',
                                    autocomplete: 'given-name',
                                    placeholder: 'Votre prénom'
                                }
                            }) }}
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="nom">Nom</label>
                            {{ form_widget(form.lastName, {
                                attr: {
                                    class: 'form-control',
                                    autocomplete: 'family-name',
                                    placeholder: 'Votre nom'
                                }
                            }) }}
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="email">Adresse e-mail</label>
                            <div class="auth-input-group"><span class="auth-input-group__icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 6 10-6"/></svg></span>
                                {{ form_widget(form.email, {
                                    attr: {
                                        class: 'form-control',
                                        autocomplete: 'email',
                                        placeholder: 'Votre adresse e-mail'
                                    }
                                }) }}
                            </div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="tel">Téléphone</label>
                            <div class="auth-input-group"><span class="auth-input-group__icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.7A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 2 .7 2.8a2 2 0 0 1-.4 2.1L8 10a16 16 0 0 0 6 6l1.4-1.4a2 2 0 0 1 2.1-.4c.9.3 1.8.5 2.8.7a2 2 0 0 1 1.7 2z"/></svg></span>

                                {{ form_widget(form.phoneNumber, {
                                    attr: {
                                        class: 'form-control',
                                        autocomplete: 'tel',
                                        placeholder: 'Votre numéro de téléphone'
                                    }
                                }) }} </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="{{ form.userProfile.label.vars.id }}">
                                Adresse (pour vos demandes)
                            </label>

                            <div class="d-flex gap-2 align-items-start">
                                <div class="flex-grow-1">
                                    {{ form_widget(form.userProfile.label, {
                                        attr: {
                                            class: 'form-control',
                                            autocomplete: 'street-address',
                                            placeholder: 'Adresse complète (rue, avenue, etc.)'
                                        }
                                    }) }}
                                </div>

                                <button
                                    class="btn btn-dash-ghost"
                                    type="button"
                                    id="detect-location"
                                >
                                    Me localiser
                                </button>
                            </div>

                            <p
                                id="geolocation-status"
                                class="small text-secondary mt-1 mb-0"
                                role="status"
                                aria-live="polite"
                            >
                                Votre adresse exacte n'est jamais publique : les artisans voient uniquement votre ville avant acceptation.
                            </p>
                        </div>

                        <div class="col-12">
                            <label class="form-label" for="{{ form.userProfile.addressLine2.vars.id }}">
                                Complément d'adresse
                            </label>

                            {{ form_widget(form.userProfile.addressLine2, {
                                attr: {
                                    class: 'form-control',
                                    autocomplete: 'address-line2',
                                    placeholder: 'Appartement, bâtiment, étage…'
                                }
                            }) }}
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label" for="{{ form.userProfile.postalCode.vars.id }}">
                                Code postal
                            </label>

                            {{ form_widget(form.userProfile.postalCode, {
                                attr: {
                                    class: 'form-control',
                                    autocomplete: 'postal-code',
                                    placeholder: 'Code postal'
                                }
                            }) }}
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label" for="{{ form.userProfile.city.vars.id }}">
                                Ville
                            </label>

                            {{ form_widget(form.userProfile.city, {
                                attr: {
                                    class: 'form-control',
                                    autocomplete: 'address-level2',
                                    placeholder: 'Ville'
                                }
                            }) }}
                        </div>
                    </div>
                </div>
            </div>

            <div class="param-panneau" id="panneau-notifications">
                <div class="dash-card">
                    <p class="param-section-titre">Mes projets</p>
                    <div class="ligne-switch">
                        <span class="ligne-switch__icone"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 3H6v18h12V8z"/><path d="M13 3v5h5M9 13h6M9 17h4"/></svg></span>
                        <div><b>Nouveaux devis reçus</b><p>E-mail + notification dès qu'un artisan répond à votre demande.</p></div>
                        <div class="form-check form-switch">{{ form_widget(form.preferences.newQuotesEnabled, {
                                attr: {
                                    class: 'form-check-input',
                                    role: 'switch',
                                    'aria-label': 'Nouveaux devis reçus'
                                }
                            }) }}
                        </div>
                    </div>
                    <div class="ligne-switch">
                        <span class="ligne-switch__icone"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12a8 8 0 1 0-3.6 6.7L21 20z"/></svg></span>
                        <div><b>Messages des artisans</b><p>Notification à chaque nouveau message reçu.</p></div>
                        <div class="form-check form-switch">
                            {{ form_widget(form.preferences.artisanMessagesEnabled, {
                                attr: {
                                    class: 'form-check-input',
                                    role: 'switch',
                                    'aria-label': 'Messages des artisans'
                                }
                            }) }}
                        </div>
                    </div>
                    <div class="ligne-switch">
                        <span class="ligne-switch__icone"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg></span>
                        <div><b>Rappels de rendez-vous</b><p>Rappel la veille et 1 h avant chaque rendez-vous.</p></div>
                        <div class="form-check form-switch">
                            {{ form_widget(form.preferences.appointmentRemindersEnabled, {
                                attr: {
                                    class: 'form-check-input',
                                    role: 'switch',
                                    'aria-label': 'Rappels de rendez-vous'
                                }
                            }) }}
                        </div>
                    </div>
                    <div class="ligne-switch">
                        <span class="ligne-switch__icone"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 6.6 7 .8-5.2 4.8L18.3 21 12 17.4 5.7 21l1.5-6.8L2 9.4l7-.8z" fill="currentColor" stroke="none"/></svg></span>
                        <div><b>Invitations à laisser un avis</b><p>Après chaque projet terminé, pour aider la communauté.</p></div>
                        <div class="form-check form-switch">
                            {{ form_widget(form.preferences.reviewInvitationsEnabled, {
                                attr: {
                                    class: 'form-check-input',
                                    role: 'switch'
                                }
                            }) }}
                        </div>
                    </div>
                    <div class="ligne-switch">
                        <span class="ligne-switch__icone"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 6 10-6"/></svg></span>
                        <div><b>Conseils et inspirations TrouveMoi</b><p>Idées de projets et bonnes pratiques (1 à 2 par mois).</p></div>
                        <div class="form-check form-switch">
                            {{ form_widget(form.marketingConsent, {
                                attr: {
                                    class: 'form-check-input',
                                    role: 'switch'
                                }
                            }) }}
                        </div>
                    </div>
                </div>
            </div>

            <div class="param-panneau" id="panneau-confidentialite">
                <div class="dash-card mb-3">
                    <p class="param-section-titre">Visibilité</p>
                    <div class="ligne-switch">
                        <span class="ligne-switch__icone"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 3.6-6 8-6s8 2 8 6"/></svg></span>
                        <div><b>Profil visible par les artisans</b><p>Vos coordonnées sont visibles lorsque vous avez accepté un devis.</p></div>
                        <div class="form-check form-switch">
                            {{ form_widget(form.preferences.profileVisibleToArtisans, {
                                attr: {
                                    class: 'form-check-input',
                                    role: 'switch'
                                }
                            }) }}
                        </div>
                    </div>
                    <div class="ligne-switch">
                        <span class="ligne-switch__icone"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.7A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 2 .7 2.8a2 2 0 0 1-.4 2.1L8 10a16 16 0 0 0 6 6l1.4-1.4a2 2 0 0 1 2.1-.4c.9.3 1.8.5 2.8.7a2 2 0 0 1 1.7 2z"/></svg></span>
                        <div><b>Téléphone partagé après acceptation</b><p>Votre numéro n'est transmis qu'aux artisans dont vous acceptez le devis.</p></div>
                        <div class="form-check form-switch">
                            {{ form_widget(form.preferences.phoneSharedAfterAcceptance, {
                                attr: {
                                    class: 'form-check-input',
                                    role: 'switch'
                                }
                            }) }}
                        </div>
                    </div>
                    <p class="param-section-titre">Vos données (RGPD)</p>
                    <div class="d-flex gap-2 flex-wrap">
                        <button class="btn btn-dash-ghost" type="button"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12M8 11l4 4 4-4"/><path d="M4 17v3a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-3"/></svg>Télécharger mes données</button>
                    </div>
                    <p class="small text-secondary mt-2 mb-0">Export complet de vos demandes, messages et avis au format lisible, envoyé par e-mail sous 48 h.</p>
                </div>
                <div class="zone-danger">
                    <b><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3 2 20h20z"/><path d="M12 10v4M12 17h.01"/></svg> Zone sensible</b>
                    <p>La suppression de votre compte est définitive : demandes, messages, projets et avis seront effacés après un délai légal de 30 jours.</p>
                    <button class="btn-danger-ghost" type="button">Supprimer mon compte</button>
                </div>
            </div>

            <div class="param-panneau" id="panneau-securite">
                <div class="dash-card">
                    <p class="param-section-titre">Mot de passe</p>
                    <div class="row g-3">
                        <div class="col-12 col-md-4">
                            <label class="form-label" for="mdp-actuel">Mot de passe actuel</label>
                            <input type="password" class="form-control" id="mdp-actuel" autocomplete="current-password" placeholder="••••••••">
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label" for="mdp-nouveau">Nouveau mot de passe</label>
                            <input type="password" class="form-control" id="mdp-nouveau" autocomplete="new-password" placeholder="8 caractères minimum">
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label" for="mdp-confirme">Confirmation</label>
                            <input type="password" class="form-control" id="mdp-confirme" autocomplete="new-password" placeholder="Retapez le mot de passe">
                        </div>
                    </div>
                    <button class="btn btn-dash-ghost mt-3" type="button"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="10" width="18" height="11" rx="2"/><path d="M7 10V7a5 5 0 0 1 10 0v3"/></svg>Mettre à jour le mot de passe</button>

                    <p class="param-section-titre">Double authentification</p>
                    <div class="ligne-switch">
                        <span class="ligne-switch__icone"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-3.5 8-10V5l-8-3-8 3v7c0 6.5 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg></span>
                        <div><b>Validation en deux étapes (2FA)</b><p>Code de confirmation par SMS à chaque nouvelle connexion.</p></div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" role="switch" id="s-2fa" aria-label="Validation en deux étapes (2FA)">
                        </div>
                    </div>

                    <p class="param-section-titre">Sessions actives</p>

                    {% for session in sessions %}
                        {% set est_courante = session.sessionToken == currentSessionToken %}
                        <div class="session">
                            <span class="session__icone">
                            {% if 'iPhone' in session.deviceLabel or 'iPad' in session.deviceLabel or 'Android' in session.deviceLabel %}
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="7" y="2" width="10" height="20" rx="2"/><path d="M11 18h2"/></svg>
                            {% else %}
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="13" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                            {% endif %}
                            </span>
                            <div>
                                <b>{{ session.deviceLabel }}{% if est_courante %} <span class="chip chip--accepte">CET APPAREIL</span>{% endif %}</b>
                                <p>
                                    {{ session.city ?? 'Localisation inconnue' }}{% if session.countryCode %}, {{ session.countryCode }}{% endif %}
                                    · Dernière activité : {{ session.lastActivityAt|ago }}
                                </p>
                            </div>
                            {% if not est_courante %}
                                <button class="btn btn-dash-ghost btn-sm" type="button">Déconnecter</button>
                            {% endif %}
                        </div>
                    {% else %}
                        <div class="session"><div><p>Aucune session active.</p></div></div>
                    {% endfor %}
                </div>
            </div>

        </div>
    </div>
    {{ form_widget(form.userProfile.addressLine1) }}
    {{ form_widget(form.userProfile.district) }}
    {{ form_widget(form.userProfile.region) }}
    {{ form_widget(form.userProfile.department) }}
    {{ form_widget(form.userProfile.countryCode) }}
    {{ form_widget(form.userProfile.formattedAddress) }}
    {{ form_widget(form.userProfile.providerPlaceId) }}
    {{ form_widget(form.userProfile.providerName) }}
    {{ form_widget(form.userProfile.latitude) }}
    {{ form_widget(form.userProfile.longitude) }}
    {{ form_end(form) }}
{% endblock %}

{% block javascripts %}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            /*
             * Navigation entre les panneaux des paramètres.
             */
            document.querySelectorAll('.param-nav__lien').forEach((link) => {
                link.addEventListener('click', () => {
                    document.querySelectorAll('.param-nav__lien').forEach((item) => {
                        item.classList.toggle('actif', item === link);
                    });

                    document.querySelectorAll('.param-panneau').forEach((panel) => {
                        panel.classList.toggle(
                            'actif',
                            panel.id === 'panneau-' + link.dataset.panneau
                        );
                    });
                });
            });

            /*
             * Géolocalisation navigateur + reverse geocoding OpenStreetMap/Nominatim.
             */
            const detectButton = document.getElementById('detect-location');
            const statusElement = document.getElementById('geolocation-status');

            const fields = {
                label: document.getElementById('{{ form.userProfile.label.vars.id }}'),
                addressLine1: document.getElementById('{{ form.userProfile.addressLine1.vars.id }}'),
                addressLine2: document.getElementById('{{ form.userProfile.addressLine2.vars.id }}'),
                postalCode: document.getElementById('{{ form.userProfile.postalCode.vars.id }}'),
                city: document.getElementById('{{ form.userProfile.city.vars.id }}'),
                district: document.getElementById('{{ form.userProfile.district.vars.id }}'),
                region: document.getElementById('{{ form.userProfile.region.vars.id }}'),
                department: document.getElementById('{{ form.userProfile.department.vars.id }}'),
                countryCode: document.getElementById('{{ form.userProfile.countryCode.vars.id }}'),
                formattedAddress: document.getElementById('{{ form.userProfile.formattedAddress.vars.id }}'),
                providerPlaceId: document.getElementById('{{ form.userProfile.providerPlaceId.vars.id }}'),
                providerName: document.getElementById('{{ form.userProfile.providerName.vars.id }}'),
                latitude: document.getElementById('{{ form.userProfile.latitude.vars.id }}'),
                longitude: document.getElementById('{{ form.userProfile.longitude.vars.id }}')
            };

            const setStatus = (message, type = 'secondary') => {
                if (!statusElement) {
                    return;
                }

                statusElement.textContent = message;
                statusElement.className = `small mt-1 mb-0 text-${type}`;
            };

            const setLoading = (loading) => {
                if (!detectButton) {
                    return;
                }

                detectButton.disabled = loading;
                detectButton.setAttribute('aria-busy', loading ? 'true' : 'false');
                detectButton.textContent = loading
                    ? 'Localisation…'
                    : 'Me localiser';
            };

            const setFieldValue = (field, value) => {
                if (!field) {
                    return;
                }

                field.value = value ?? '';

                field.dispatchEvent(new Event('input', {
                    bubbles: true
                }));

                field.dispatchEvent(new Event('change', {
                    bubbles: true
                }));
            };

            const firstValue = (object, keys) => {
                for (const key of keys) {
                    const value = object?.[key];

                    if (typeof value === 'string' && value.trim() !== '') {
                        return value.trim();
                    }
                }

                return '';
            };

            const buildAddressLine1 = (address) => {
                const houseNumber = firstValue(address, [
                    'house_number'
                ]);

                const road = firstValue(address, [
                    'road',
                    'pedestrian',
                    'street',
                    'residential',
                    'footway',
                    'path'
                ]);

                return [houseNumber, road]
                    .filter(Boolean)
                    .join(' ')
                    .trim();
            };

            const fillAddressFields = (data, requestedLatitude, requestedLongitude) => {
                const address = data.address ?? {};

                const addressLine1 = buildAddressLine1(address);

                const city = firstValue(address, [
                    'city',
                    'town',
                    'village',
                    'municipality',
                    'hamlet',
                    'locality'
                ]);

                const district = firstValue(address, [
                    'city_district',
                    'district',
                    'borough',
                    'suburb',
                    'quarter',
                    'neighbourhood'
                ]);

                const region = firstValue(address, [
                    'state',
                    'region'
                ]);

                const department = firstValue(address, [
                    'county',
                    'state_district'
                ]);

                const postalCode = firstValue(address, [
                    'postcode'
                ]);

                const countryCode = firstValue(address, [
                    'country_code'
                ]).toUpperCase();

                const osmType = data.osm_type ?? '';
                const osmId = data.osm_id ?? '';
                const placeId = data.place_id ?? '';

                let providerPlaceId = '';

                if (osmType && osmId) {
                    providerPlaceId = `${osmType}:${osmId}`;
                } else if (placeId) {
                    providerPlaceId = `place:${placeId}`;
                }

                setFieldValue(fields.label, addressLine1 || data.display_name || '');
                setFieldValue(fields.addressLine1, addressLine1);
                setFieldValue(fields.postalCode, postalCode);
                setFieldValue(fields.city, city);
                setFieldValue(fields.district, district);
                setFieldValue(fields.region, region);
                setFieldValue(fields.department, department);
                setFieldValue(fields.countryCode, countryCode);
                setFieldValue(fields.formattedAddress, data.display_name ?? '');
                setFieldValue(fields.providerPlaceId, providerPlaceId);
                setFieldValue(fields.providerName, 'OPENSTREETMAP_NOMINATIM');
                setFieldValue(fields.latitude, data.lat ?? requestedLatitude);
                setFieldValue(fields.longitude, data.lon ?? requestedLongitude);
            };

            const reverseGeocode = async (latitude, longitude) => {
                const url = new URL('https://nominatim.openstreetmap.org/reverse');

                url.searchParams.set('format', 'jsonv2');
                url.searchParams.set('lat', latitude);
                url.searchParams.set('lon', longitude);
                url.searchParams.set('addressdetails', '1');
                url.searchParams.set('namedetails', '1');
                url.searchParams.set('zoom', '18');
                url.searchParams.set('accept-language', 'fr');

                setStatus(
                    'Recherche de votre adresse avec OpenStreetMap…',
                    'secondary'
                );

                const response = await fetch(url.toString(), {
                    method: 'GET',
                    headers: {
                        Accept: 'application/json'
                    }
                });

                if (!response.ok) {
                    throw new Error(
                        `OpenStreetMap a retourné l'erreur HTTP ${response.status}.`
                    );
                }

                const data = await response.json();

                if (data.error) {
                    throw new Error(data.error);
                }

                fillAddressFields(data, latitude, longitude);
            };

            const handleGeolocationError = (error) => {
                let message = 'Impossible de détecter votre position.';

                switch (error.code) {
                    case error.PERMISSION_DENIED:
                        message = 'Vous avez refusé l’accès à votre position.';
                        break;

                    case error.POSITION_UNAVAILABLE:
                        message = 'Votre position est actuellement indisponible.';
                        break;

                    case error.TIMEOUT:
                        message = 'La détection de votre position a expiré.';
                        break;
                }

                setLoading(false);
                setStatus(message, 'danger');
                console.error('Erreur de géolocalisation :', error);
            };

            const detectLocation = () => {
                if (!navigator.geolocation) {
                    setStatus(
                        'La géolocalisation n’est pas prise en charge par ce navigateur.',
                        'danger'
                    );

                    return;
                }

                setLoading(true);
                setStatus('Recherche de votre position…', 'secondary');

                navigator.geolocation.getCurrentPosition(
                    async (position) => {
                        const latitude = position.coords.latitude.toFixed(7);
                        const longitude = position.coords.longitude.toFixed(7);

                        setFieldValue(fields.latitude, latitude);
                        setFieldValue(fields.longitude, longitude);

                        try {
                            await reverseGeocode(latitude, longitude);

                            setStatus(
                                'Votre adresse a été détectée et les champs ont été remplis.',
                                'success'
                            );
                        } catch (error) {
                            console.error('Erreur OpenStreetMap/Nominatim :', error);

                            setStatus(
                                error instanceof Error
                                    ? error.message
                                    : 'Impossible de récupérer votre adresse.',
                                'danger'
                            );
                        } finally {
                            setLoading(false);
                        }
                    },
                    handleGeolocationError,
                    {
                        enableHighAccuracy: true,
                        timeout: 15000,
                        maximumAge: 300000
                    }
                );
            };

            if (detectButton) {
                detectButton.addEventListener('click', detectLocation);
            }

            /*
             * Lancement automatique à l'ouverture de la page.
             * Le navigateur demandera l'autorisation à l'utilisateur.
             */
            detectLocation();
        });
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const btnChanger = document.getElementById('btn-changer-photo');
            const inputFile = document.getElementById('avatar-input-file');
            const apercuImage = document.getElementById('avatar-apercu-image');
            const apercuInitiales = document.getElementById('avatar-apercu-initiales');

            if (!btnChanger || !inputFile || !apercuImage) {
                return;
            }

            btnChanger.addEventListener('click', (event) => {
                event.preventDefault();
                inputFile.click();
            });

            inputFile.addEventListener('change', () => {
                const fichier = inputFile.files?.[0];

                if (!fichier) {
                    return;
                }

                const urlApercu = URL.createObjectURL(fichier);

                apercuImage.src = urlApercu;
                apercuImage.style.display = '';

                if (apercuInitiales) {
                    apercuInitiales.style.display = 'none';
                }

                apercuImage.onload = () => {
                    URL.revokeObjectURL(urlApercu);
                };
            });
        });
    </script>
{% endblock %}
